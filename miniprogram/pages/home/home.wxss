.container {
  padding: 24rpx;
  padding-bottom: 120rpx;
}

.banner-card {
  position: relative;
  height: 400rpx;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 30rpx rgba(255, 105, 180, 0.15);
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.2) 50%, transparent 100%);
}

.hover-tip {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0,0,0,0.5);
  backdrop-filter: blur(10rpx);
  padding: 16rpx 32rpx;
  border-radius: 50rpx;
}

.tip-text {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: bold;
}

.idol-info {
  position: absolute;
  bottom: 32rpx;
  left: 32rpx;
  right: 32rpx;
  display: flex;
  align-items: flex-end;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  border: 6rpx solid rgba(255,255,255,0.3);
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.2);
  margin-right: 24rpx;
}

.idol-detail {
  flex: 1;
}

.idol-name {
  display: block;
  color: #FFFFFF;
  font-size: 40rpx;
  font-weight: bold;
  font-family: serif;
  margin-bottom: 8rpx;
}

.idol-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.nickname {
  color: rgba(255,255,255,0.9);
  font-size: 20rpx;
  background: rgba(255,255,255,0.2);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.color-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 10rpx;
  border: 2rpx solid rgba(255,255,255,0.5);
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  margin-top: 32rpx;
}

.stat-card {
  background: rgba(255,255,255,0.8);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(255, 105, 180, 0.1);
  border-top: 2rpx solid rgba(255,255,255,0.5);
}

.stat-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 16rpx;
}

.stat-icon.heart {
  background: #FFE4EC;
}

.stat-icon.clock {
  background: #F3E8FF;
}

.icon {
  font-size: 36rpx;
}

.stat-label {
  display: block;
  color: #999999;
  font-size: 20rpx;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.stat-value {
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.number {
  font-size: 48rpx;
  font-weight: bold;
  color: #333333;
  font-family: 'Courier New', Courier, monospace;
  letter-spacing: 0.02em;
  display: inline-block;
  min-width: 80rpx;
  text-align: center;
}

.unit {
  font-size: 24rpx;
  color: #999999;
  font-weight: bold;
  margin-left: 4rpx;
}

.section-card {
  background: rgba(255,255,255,0.8);
  backdrop-filter: blur(20rpx);
  border-radius: 32rpx;
  padding: 32rpx;
  margin-top: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 105, 180, 0.1);
  border-top: 2rpx solid rgba(255,255,255,0.5);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.title-bar {
  width: 12rpx;
  height: 48rpx;
  background: linear-gradient(180deg, #FFB6C1, #FF69B4);
  border-radius: 6rpx;
}

.section-title text {
  font-size: 32rpx;
  font-weight: bold;
  font-family: serif;
  color: #333333;
}

.more-btn {
  color: #FF69B4;
  font-size: 24rpx;
  font-weight: bold;
}

.anniversary-item {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.6);
  padding: 24rpx;
  border-radius: 24rpx;
  margin-bottom: 16rpx;
}

.anniversary-date {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.anniversary-date.bg-pink-300 {
  background: #FFB6C1;
}

.anniversary-date.bg-lavender-300 {
  background: #D8BFD8;
}

.anniversary-date.bg-blue-300 {
  background: #87CEEB;
}

.date-day {
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: bold;
  font-family: serif;
}

.anniversary-info {
  flex: 1;
}

.anniversary-title {
  display: block;
  color: #333333;
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 4rpx;
}

.anniversary-type {
  color: #999999;
  font-size: 18rpx;
  letter-spacing: 2rpx;
}

.anniversary-countdown {
  text-align: right;
  min-width: 120rpx;
}

.countdown {
  display: flex;
  align-items: baseline;
  justify-content: flex-end;
  color: #FF69B4;
  margin-bottom: 4rpx;
}

.countdown-label {
  font-size: 18rpx;
  font-weight: bold;
}

.countdown-number {
  font-size: 40rpx;
  font-weight: bold;
  font-family: 'Courier New', Courier, monospace;
  line-height: 1;
  letter-spacing: 0.02em;
  display: inline-block;
  min-width: 60rpx;
  text-align: right;
}

.countdown-date {
  color: #999999;
  font-size: 18rpx;
  font-weight: bold;
}

.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 24rpx;
  border: 3rpx dashed #FFE4EC;
  border-radius: 24rpx;
  margin-top: 24rpx;
  color: #FFB6C1;
  font-size: 28rpx;
  font-weight: bold;
}

.add-icon {
  font-size: 32rpx;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 100;
}

.menu-modal {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 101;
  width: 500rpx;
}

.modal-content {
  background: #FFFFFF;
  border-radius: 40rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.2);
}

.modal-header {
  padding: 32rpx;
  text-align: center;
  border-bottom: 2rpx solid #FFE4EC;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.menu-list {
  padding: 16rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-radius: 24rpx;
}

.menu-item:active {
  background: #FFF5F5;
}

.menu-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.menu-icon.pink {
  background: #FFE4EC;
}

.menu-icon.purple {
  background: #F3E8FF;
}

.menu-icon text {
  font-size: 36rpx;
}

.menu-text {
  flex: 1;
}

.menu-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 4rpx;
}

.menu-desc {
  display: block;
  font-size: 20rpx;
  color: #999999;
}

.modal-footer {
  padding: 16rpx;
  border-top: 2rpx solid #FFE4EC;
}

.cancel-btn {
  width: 100%;
  padding: 24rpx;
  background: #F5F5F5;
  color: #666666;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 24rpx;
  border: none;
}

.cancel-btn:active {
  background: #E8E8E8;
}