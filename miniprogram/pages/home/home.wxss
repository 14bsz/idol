.container {
  padding: 24rpx;
  padding-bottom: 120rpx;
}

.banner-card {
  position: relative;
  height: 400rpx;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 30rpx rgba(255, 105, 180, 0.15);
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.2) 50%, transparent 100%);
}

.hover-tip {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0,0,0,0.5);
  backdrop-filter: blur(10rpx);
  padding: 16rpx 32rpx;
  border-radius: 50rpx;
}

.tip-text {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: bold;
}

.idol-info {
  position: absolute;
  bottom: 32rpx;
  left: 32rpx;
  right: 32rpx;
  display: flex;
  align-items: flex-end;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  border: 6rpx solid rgba(255,255,255,0.3);
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.2);
  margin-right: 24rpx;
}

.idol-detail {
  flex: 1;
}

.idol-name {
  display: block;
  color: #FFFFFF;
  font-size: 40rpx;
  font-weight: bold;
  font-family: serif;
  margin-bottom: 8rpx;
}

.idol-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.nickname {
  color: rgba(255,255,255,0.9);
  font-size: 20rpx;
  background: rgba(255,255,255,0.2);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.color-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 10rpx;
  border: 2rpx solid rgba(255,255,255,0.5);
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  margin-top: 32rpx;
}

.stat-card {
  background: rgba(255,255,255,0.8);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(255, 105, 180, 0.1);
  border-top: 2rpx solid rgba(255,255,255,0.5);
}

.stat-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 16rpx;
}

.stat-icon.heart {
  background: #FFE4EC;
}

.stat-icon.clock {
  background: #F3E8FF;
}

.icon {
  font-size: 36rpx;
}

.stat-label {
  display: block;
  color: #999999;
  font-size: 20rpx;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.stat-value {
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.number {
  font-size: 48rpx;
  font-weight: bold;
  color: #333333;
  font-family: 'Courier New', Courier, monospace;
  letter-spacing: 0.02em;
  display: inline-block;
  min-width: 80rpx;
  text-align: center;
}

.unit {
  font-size: 24rpx;
  color: #999999;
  font-weight: bold;
  margin-left: 4rpx;
}

.section-card {
  background: rgba(255,255,255,0.8);
  backdrop-filter: blur(20rpx);
  border-radius: 32rpx;
  padding: 32rpx;
  margin-top: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 105, 180, 0.1);
  border-top: 2rpx solid rgba(255,255,255,0.5);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.title-bar {
  width: 12rpx;
  height: 48rpx;
  background: linear-gradient(180deg, #FFB6C1, #FF69B4);
  border-radius: 6rpx;
}

.section-title text {
  font-size: 32rpx;
  font-weight: bold;
  font-family: serif;
  color: #333333;
}

.more-btn {
  color: #FF69B4;
  font-size: 24rpx;
  font-weight: bold;
}

.anniversary-item {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.6);
  padding: 24rpx;
  border-radius: 24rpx;
  margin-bottom: 16rpx;
}

.anniversary-date {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.anniversary-date.bg-pink-300 {
  background: #FFB6C1;
}

.anniversary-date.bg-lavender-300 {
  background: #D8BFD8;
}

.anniversary-date.bg-blue-300 {
  background: #87CEEB;
}

.date-day {
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: bold;
  font-family: serif;
}

.anniversary-info {
  flex: 1;
}

.anniversary-title {
  display: block;
  color: #333333;
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 4rpx;
}

.anniversary-type {
  color: #999999;
  font-size: 18rpx;
  letter-spacing: 2rpx;
}

.anniversary-countdown {
  text-align: right;
  min-width: 120rpx;
}

.countdown {
  display: flex;
  align-items: baseline;
  justify-content: flex-end;
  color: #FF69B4;
  margin-bottom: 4rpx;
}

.countdown-label {
  font-size: 18rpx;
  font-weight: bold;
}

.countdown-number {
  font-size: 40rpx;
  font-weight: bold;
  font-family: 'Courier New', Courier, monospace;
  line-height: 1;
  letter-spacing: 0.02em;
  display: inline-block;
  min-width: 60rpx;
  text-align: right;
}

.countdown-date {
  color: #999999;
  font-size: 18rpx;
  font-weight: bold;
}

.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 24rpx;
  border: 3rpx dashed #FFE4EC;
  border-radius: 24rpx;
  margin-top: 24rpx;
  color: #FFB6C1;
  font-size: 28rpx;
  font-weight: bold;
}

.add-icon {
  font-size: 32rpx;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 100;
}

.menu-modal {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 101;
  width: 500rpx;
}

.modal-content {
  background: #FFFFFF;
  border-radius: 40rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.2);
}

.modal-header {
  padding: 32rpx;
  text-align: center;
  border-bottom: 2rpx solid #FFE4EC;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.menu-list {
  padding: 16rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-radius: 24rpx;
}

.menu-item:active {
  background: #FFF5F5;
}

.menu-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.menu-icon.pink {
  background: #FFE4EC;
}

.menu-icon.purple {
  background: #F3E8FF;
}

.menu-icon text {
  font-size: 36rpx;
}

.menu-text {
  flex: 1;
}

.menu-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 4rpx;
}

.menu-desc {
  display: block;
  font-size: 20rpx;
  color: #999999;
}

.modal-footer {
  padding: 16rpx;
  border-top: 2rpx solid #FFE4EC;
}

.cancel-btn {
  width: 100%;
  padding: 24rpx;
  background: #F5F5F5;
  color: #666666;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 24rpx;
  border: none;
}

.cancel-btn:active {
  background: #E8E8E8;
}


/* ====== 未登录状态 Emoji 图标动画 ====== */

/* ✨ Logo - 浮动闪烁 */
@keyframes logo-sparkle {
  0%, 100% {
    transform: translateY(0) rotate(0deg) scale(1);
    filter: brightness(1);
  }
  25% {
    transform: translateY(-8rpx) rotate(10deg) scale(1.1);
    filter: brightness(1.2);
  }
  50% {
    transform: translateY(-12rpx) rotate(-5deg) scale(1.05);
    filter: brightness(1.3);
  }
  75% {
    transform: translateY(-6rpx) rotate(5deg) scale(1.08);
    filter: brightness(1.1);
  }
}

/* 📝 时光日记 - 书写动画 */
@keyframes diary-write {
  0%, 100% {
    transform: rotate(0deg) translate(0, 0);
  }
  20% {
    transform: rotate(-8deg) translate(-2rpx, 2rpx);
  }
  40% {
    transform: rotate(8deg) translate(2rpx, -2rpx);
  }
  60% {
    transform: rotate(-5deg) translate(-1rpx, 1rpx);
  }
  80% {
    transform: rotate(3deg) translate(1rpx, -1rpx);
  }
}

/* 📷 精彩收藏 - 相机快门 */
@keyframes camera-click {
  0%, 100% {
    transform: scale(1) rotate(0deg);
  }
  10%, 20% {
    transform: scale(0.85) rotate(-5deg);
  }
  15% {
    transform: scale(1.15) rotate(5deg);
  }
  30%, 50% {
    transform: scale(1) rotate(0deg);
  }
  60% {
    transform: rotate(10deg);
  }
  70% {
    transform: rotate(-10deg);
  }
  80% {
    transform: rotate(0deg);
  }
}

/* 🎂 纪念日 - 蜡烛摇曳 */
@keyframes cake-candle {
  0%, 100% {
    transform: translateY(0) rotate(0deg);
    filter: brightness(1);
  }
  25% {
    transform: translateY(-4rpx) rotate(-3deg);
    filter: brightness(1.15);
  }
  50% {
    transform: translateY(-6rpx) rotate(3deg);
    filter: brightness(1.2);
  }
  75% {
    transform: translateY(-3rpx) rotate(-2deg);
    filter: brightness(1.1);
  }
}

/* 📊 时光回顾 - 数据波动 */
@keyframes chart-wave {
  0%, 100% {
    transform: translateY(0) scaleY(1);
  }
  25% {
    transform: translateY(-3rpx) scaleY(1.05);
  }
  50% {
    transform: translateY(-5rpx) scaleY(0.95);
  }
  75% {
    transform: translateY(-2rpx) scaleY(1.03);
  }
}

/* 💡 提示灯泡 - 闪烁 */
@keyframes bulb-blink {
  0%, 100% {
    transform: scale(1);
    filter: brightness(1);
  }
  50% {
    transform: scale(1.15);
    filter: brightness(1.3) drop-shadow(0 0 10rpx rgba(236, 72, 153, 0.6));
  }
}

/* 页面淡入动画 */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.guest-view {
  animation: fadeInUp 0.6s ease-out;
  margin-top: -8rpx;
  margin-bottom: -80rpx;
}

/* ====== 未登录状态 - 欢迎卡片 ====== */
.guest-welcome-card {
  padding: 44rpx 40rpx 34rpx;
  border-radius: 48rpx;
  margin-bottom: 28rpx;
  background: linear-gradient(135deg, #fce4ec 0%, #f3e5f5 50%, #ede9fe 100%);
  border-top: 2rpx solid rgba(255, 255, 255, 0.7);
  box-shadow: 0 12rpx 40rpx -12rpx rgba(236, 72, 153, 0.15);
  text-align: center;
  position: relative;
  overflow: hidden;
}

.guest-welcome-card::before {
  content: '';
  position: absolute;
  top: -50rpx;
  right: -50rpx;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
}

.guest-welcome-card::after {
  content: '';
  position: absolute;
  bottom: -30rpx;
  left: -30rpx;
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
}

.guest-welcome-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: white;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 18rpx;
  box-shadow: 0 8rpx 28rpx -8rpx rgba(236, 72, 153, 0.2);
  position: relative;
  z-index: 1;
}

.guest-welcome-title {
  font-size: 42rpx;
  font-weight: bold;
  color: #1e293b;
  display: block;
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
  position: relative;
  z-index: 1;
}

.guest-welcome-desc {
  font-size: 26rpx;
  color: #64748b;
  display: block;
  line-height: 1.5;
  position: relative;
  z-index: 1;
}

.guest-welcome-divider {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin: 16rpx 0 12rpx;
  position: relative;
  z-index: 1;
}

.divider-dot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: rgba(236, 72, 153, 0.3);
}

.divider-line {
  width: 80rpx;
  height: 2rpx;
  background: linear-gradient(to right, transparent, rgba(236, 72, 153, 0.3), transparent);
}

.guest-welcome-sub {
  font-size: 22rpx;
  color: #94a3b8;
  display: block;
  position: relative;
  z-index: 1;
}

/* ====== 功能卡片网格 ====== */
.guest-feature-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 22rpx;
  margin-bottom: 28rpx;
}

.guest-feature-card {
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  border-radius: 32rpx;
  padding: 28rpx 20rpx 24rpx;
  text-align: center;
  border-top: 2rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 8rpx 24rpx -8rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.guest-feature-card:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 12rpx -4rpx rgba(0, 0, 0, 0.06);
}

.guest-feature-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 14rpx;
}

.feature-icon-pink {
  background: linear-gradient(135deg, #fce4ec, #fbc2d8);
}

.feature-icon-purple {
  background: linear-gradient(135deg, #f3e5f5, #e1bee7);
}

.feature-emoji {
  font-size: 42rpx;
  display: inline-block;
}

.guest-feature-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #1e293b;
  display: block;
  margin-bottom: 6rpx;
}

.guest-feature-desc {
  font-size: 22rpx;
  color: #94a3b8;
  display: block;
  line-height: 1.4;
}

/* ====== 体验提示 ====== */
.guest-tip-card {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 24rpx 28rpx;
  border-radius: 28rpx;
  margin-bottom: 36rpx;
  background: rgba(236, 72, 153, 0.04);
  border: 2rpx solid rgba(236, 72, 153, 0.1);
}

.guest-tip-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.guest-tip-text {
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.5;
}

/* ====== 登录按钮区域 ====== */
.guest-login-action {
  text-align: center;
  padding-top: 4rpx;
}

.guest-login-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 28rpx 76rpx;
  border-radius: 9999rpx;
  background: linear-gradient(135deg, #f472b6, #ec4899);
  color: white;
  font-size: 30rpx;
  font-weight: bold;
  box-shadow: 0 14rpx 44rpx -14rpx rgba(236, 72, 153, 0.5);
  position: relative;
  overflow: hidden;
}

.guest-login-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 50%;
  height: 100%;
  background: linear-gradient(to right, rgba(255,255,255,0) 0%, rgba(255,255,255,0.25) 50%, rgba(255,255,255,0) 100%);
  transform: skewX(-25deg);
  animation: sweep 4s infinite;
}

.guest-login-btn-arrow {
  font-size: 30rpx;
  transition: transform 0.3s ease;
}

.guest-login-btn:active .guest-login-btn-arrow {
  transform: translateX(6rpx);
}

.guest-login-hint {
  font-size: 22rpx;
  color: #94a3b8;
  display: block;
  margin-top: 24rpx;
}

@keyframes sweep {
  0% { left: -100%; }
  20% { left: 200%; }
  100% { left: 200%; }
}

/* 功能卡片交错淡入 */
.guest-feature-grid .guest-feature-card:nth-child(1) {
  animation: fadeInUp 0.5s ease-out 0.1s both;
}
.guest-feature-grid .guest-feature-card:nth-child(2) {
  animation: fadeInUp 0.5s ease-out 0.2s both;
}
.guest-feature-grid .guest-feature-card:nth-child(3) {
  animation: fadeInUp 0.5s ease-out 0.3s both;
}
.guest-feature-grid .guest-feature-card:nth-child(4) {
  animation: fadeInUp 0.5s ease-out 0.4s both;
}

/* Emoji 动画 */
.feature-emoji-diary {
  animation: diary-write 3s ease-in-out infinite;
}
.feature-emoji-cake {
  animation: cake-candle 2.5s ease-in-out infinite;
}
.feature-emoji-chart {
  animation: chart-wave 3s ease-in-out infinite;
}

.feature-card-large {
  animation: fadeInUp 0.8s ease-out;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.feature-card-large:active {
  transform: scale(0.98);
}

.button-hover {
  transform: scale(0.95);
  opacity: 0.9;
  transition: all 0.2s ease;
}
