.container {
  min-height: 100vh;
  background: #FFF5F5;
  display: flex;
  flex-direction: column;
  width: 100%;
  box-sizing: border-box;
  overflow-x: hidden;
  padding: 0;
  padding-bottom: 0;
}

.header {
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  background: rgba(255,255,255,0.9);
  backdrop-filter: blur(20rpx);
  border-bottom: 2rpx solid rgba(255, 228, 236, 0.5);
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  box-sizing: border-box;
}

.nav-left {
  position: absolute;
  left: 32rpx;
  display: flex;
  align-items: center;
  z-index: 101;
}

.nav-icon {
  font-size: 48rpx;
  color: #999999;
  font-weight: 300;
  line-height: 1;
}

.nav-title {
  width: 100%;
  text-align: center;
  font-size: 38rpx;
  font-weight: bold;
  color: #333333;
  font-family: serif;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  letter-spacing: 2rpx;
}

.nav-right {
  position: absolute;
  right: 0;
  display: flex;
  justify-content: flex-end;
  z-index: 101;
}

.content-scroll {
  flex: 1;
  padding: 0;
}

.content-inner {
  padding: 32rpx;
  padding-bottom: 60rpx;
  box-sizing: border-box;
}

.section-label {
  display: block;
  font-size: 20rpx;
  color: #999999;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.category-section {
  margin-bottom: 40rpx;
}

.category-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.category-item {
  padding: 12rpx 28rpx;
  background: #FFFFFF;
  color: #999999;
  font-size: 24rpx;
  font-weight: bold;
  border-radius: 28rpx;
  border: 2rpx solid rgba(0,0,0,0.05);
  transition: all 0.3s;
}

.category-item.active {
  background: linear-gradient(135deg, #FF69B4, #FFB6C1);
  border-color: transparent;
  color: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(255, 105, 180, 0.25);
  transform: scale(1.05);
}

.image-section {
  margin-bottom: 24rpx;
}

.image-preview {
  position: relative;
  aspect-ratio: 1;
  border-radius: 32rpx;
  overflow: hidden;
  background: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(255, 105, 180, 0.1);
}

.preview-image {
  width: 100%;
  height: 100%;
}

.image-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s;
}

.image-preview:active .image-overlay {
  opacity: 1;
}

.overlay-text {
  padding: 12rpx 28rpx;
  background: rgba(255,255,255,0.9);
  color: #333333;
  font-size: 24rpx;
  font-weight: bold;
  border-radius: 32rpx;
}

.image-upload {
  aspect-ratio: 1;
  border-radius: 32rpx;
  background: rgba(255,255,255,0.3);
  border: 4rpx dashed #FFE4EC;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #FFB6C1;
}

.upload-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(255, 105, 180, 0.1);
  margin-bottom: 24rpx;
  transition: transform 0.3s;
}

.image-upload:active .upload-icon {
  transform: scale(1.1);
}

.icon {
  font-size: 56rpx;
}

.upload-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}

.loading-icon {
  font-size: 56rpx;
  animation: spin 1s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 24rpx;
  font-weight: bold;
}

.upload-text {
  text-align: center;
}

.text-main {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #FFB6C1;
  margin-bottom: 8rpx;
}

.text-sub {
  display: block;
  font-size: 20rpx;
  color: #FFD1DC;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.url-section {
  margin-bottom: 40rpx;
}

.url-input-wrapper {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  border: 2rpx solid rgba(0,0,0,0.05);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.url-icon {
  font-size: 28rpx;
}

.url-input {
  flex: 1;
  font-size: 24rpx;
  color: #333333;
  background: transparent;
}

.notes-section {
  margin-bottom: 40rpx;
}

.notes-input {
  width: 100%;
  min-height: 200rpx;
  padding: 32rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  border: 2rpx solid rgba(0,0,0,0.03);
  font-size: 28rpx;
  line-height: 1.6;
  color: #333333;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  box-sizing: border-box;
}

.tags-section {
  margin-bottom: 40rpx;
}

.tags-wrapper {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  align-items: center;
}

.tag-item {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 20rpx;
  background: linear-gradient(135deg, #FFF0F5, #FFE4EC);
  border-radius: 9999rpx;
  border: 2rpx solid rgba(244,114,182,0.2);
}

.tag-text {
  font-size: 24rpx;
  color: #ec4899;
  font-weight: bold;
}

.tag-close {
  font-size: 28rpx;
  color: #f472b6;
  line-height: 1;
  font-weight: 300;
}

.tag-input-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  border-radius: 9999rpx;
  background: rgba(255,255,255,0.8);
  border: 2rpx dashed rgba(244,114,182,0.3);
}

.add-tag-icon {
  font-size: 36rpx;
  color: #f472b6;
  font-weight: 300;
  line-height: 1;
}

.tag-input-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 16rpx;
  background: #FFFFFF;
  border-radius: 9999rpx;
  border: 2rpx solid rgba(244,114,182,0.3);
}

.tag-input {
  flex: 1;
  min-width: 160rpx;
  font-size: 24rpx;
  color: #333333;
}

.tag-confirm {
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #f472b6, #ec4899);
  color: white;
  font-size: 24rpx;
  font-weight: bold;
  border-radius: 9999rpx;
}

.tag-cancel {
  padding: 8rpx 16rpx;
  color: #94a3b8;
  font-size: 24rpx;
}

.tag-suggestions {
  margin-top: 16rpx;
}

.suggestion-title {
  font-size: 22rpx;
  color: #94a3b8;
  margin-bottom: 12rpx;
  display: block;
}

.suggestion-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.suggestion-item {
  padding: 8rpx 20rpx;
  background: #FFFFFF;
  border-radius: 9999rpx;
  font-size: 22rpx;
  color: #64748b;
  border: 1rpx solid #f1f5f9;
}

.bottom-action {
  padding: 48rpx 0 80rpx;
}

.save-btn-large {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #FF69B4, #FFB6C1);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 32rpx -8rpx rgba(255, 105, 180, 0.5);
  border: none;
}

.save-btn-large.disabled {
  background: #E8E8E8;
  color: #CCCCCC;
  box-shadow: none;
}
