<view class="container" style="padding-top: {{totalNavHeight + 20}}px;">
  <view class="header" style="height: {{navHeight + navTop + 20}}px; padding-top: {{navTop}}px;">
    <view class="nav-left" bindtap="goBack" style="top: {{navTop}}px; height: {{navHeight + 20}}px;">
      <text class="nav-icon">‹</text>
    </view>
    <view class="nav-title" style="line-height: {{navHeight + 20}}px;">新增收藏</view>
    <view class="nav-right" style="width: {{menuButtonWidth}}px; padding-right: {{menuButtonRight}}rpx;">
      <!-- 保存按钮现在避开了胶囊 -->
    </view>
  </view>

  <scroll-view class="content-scroll" scroll-y="true">
    <view class="content-inner">
      <view class="category-section">
        <text class="section-label">选择分类</text>
        <view class="category-list">
          <view class="category-item {{category === item ? 'active' : ''}}" wx:for="{{categories}}" wx:key="*this" bindtap="selectCategory" data-category="{{item}}">
            {{item}}
          </view>
          <view class="category-item category-create-item" bindtap="addCustomCategory">
            + 自定义
          </view>
        </view>
        <text class="category-tip">支持保留默认分类，也可以添加你自己的收藏分类</text>
      </view>

      <view class="image-section">
        <text class="section-label">添加物料</text>
        
        <view class="image-preview" wx:if="{{imageUrl}}">
          <image class="preview-image" src="{{imageUrl}}" mode="aspectFill"></image>
          <view class="image-overlay" bindtap="clearImage">
            <text class="overlay-text">点击更换</text>
          </view>
        </view>
        
        <view class="image-upload" wx:else bindtap="uploadImage">
          <view class="upload-icon" wx:if="{{!isUploading}}">
            <text class="icon">📷</text>
          </view>
          <view class="upload-loading" wx:else>
            <text class="loading-icon">✨</text>
            <text class="loading-text">正在冲印中...</text>
          </view>
          <view class="upload-text" wx:if="{{!isUploading}}">
            <text class="text-main">点击上传神图/小卡</text>
            <text class="text-sub">Supports JPG, PNG</text>
          </view>
        </view>
      </view>

      <view class="url-section">
        <view class="url-input-wrapper">
          <text class="url-icon">🔗</text>
          <input 
            class="url-input" 
            placeholder="或者在此粘贴图片 URL..." 
            value="{{imageUrl}}" 
            bindinput="onUrlInput"
          />
        </view>
      </view>

      <view class="notes-section">
        <text class="section-label">心动笔记</text>
        <textarea 
          class="notes-input" 
          placeholder="记录下当时的心情和感受吧...." 
          value="{{notes}}" 
          bindinput="onNotesInput"
          maxlength="500"
          auto-height
        ></textarea>
      </view>

      <view class="date-section">
        <text class="section-label">活动日期（可选）</text>
        <view class="date-picker-wrapper">
          <picker 
            mode="date" 
            value="{{eventDate}}" 
            bindchange="onDateChange"
            end="{{maxDate}}"
          >
            <view class="date-display {{eventDate ? 'has-date' : ''}}">
              <text class="date-icon">📅</text>
              <text class="date-text">{{eventDate || '选择这张图片的时间'}}</text>
            </view>
          </picker>
          <text wx:if="{{eventDate}}" class="date-clear" bindtap="clearEventDate">×</text>
        </view>
        <text class="date-hint">记录这张图片对应的活动或拍摄日期</text>
      </view>

      <view class="tags-section">
        <text class="section-label">专属标签</text>
        <view class="tags-wrapper">
          <view class="tag-item" wx:for="{{tags}}" wx:key="*this" wx:if="{{tags.length > 0}}">
            <text class="tag-text">{{item}}</text>
            <text class="tag-close" bindtap="removeTag" data-index="{{index}}">×</text>
          </view>
          <view class="tag-input-wrapper" wx:if="{{!showTagInput}}">
            <text class="add-tag-icon" bindtap="showTagInputBox">+</text>
          </view>
          <view class="tag-input-box" wx:else>
            <input 
              class="tag-input" 
              placeholder="输入标签，回车添加" 
              value="{{tagInput}}" 
              bindinput="onTagInput"
              confirm-type="done"
              bindconfirm="addTag"
            />
            <text class="tag-confirm" bindtap="addTag">添加</text>
            <text class="tag-cancel" bindtap="hideTagInputBox">取消</text>
          </view>
        </view>
        <view class="tag-suggestions" wx:if="{{tagSuggestions.length > 0 && showTagInput}}">
          <text class="suggestion-title">常用标签：</text>
          <view class="suggestion-list">
            <text 
              class="suggestion-item" 
              wx:for="{{tagSuggestions}}" 
              wx:key="*this"
              bindtap="selectSuggestion"
              data-tag="{{item}}"
            >{{item}}</text>
          </view>
        </view>
      </view>

      <view class="bottom-action">
        <button class="save-btn-large {{!imageUrl ? 'disabled' : ''}}" bindtap="saveCollection" disabled="{{!imageUrl}}">
          确认保存
        </button>
      </view>
    </view>
  </scroll-view>
</view>
