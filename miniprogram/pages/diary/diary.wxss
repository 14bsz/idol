  margin-top: -10rpx;
  display: block;
}

/* 标签筛选区域 */
.tag-filter-section {
  margin-top: 32rpx;
  margin-bottom: 16rpx;
}

.tag-filter-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.tag-filter-title {
  font-size: 24rpx;
  font-weight: bold;
  color: #64748b;
  letter-spacing: 0.05em;
}

.tag-clear-btn {
  font-size: 24rpx;
  color: #f472b6;
  font-weight: 600;
  padding: 8rpx 20rpx;
  background: rgba(244, 114, 182, 0.1);
  border-radius: 20rpx;
}

.tag-filter-scroll {
  white-space: nowrap;
  margin-bottom: 12rpx;
}

.tag-filter-list {
  display: inline-flex;
  gap: 12rpx;
  padding: 4rpx 0;
}

.tag-filter-item {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 2rpx solid #f1f5f9;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #64748b;
  font-weight: 500;
  transition: all 0.3s ease;
  white-space: nowrap;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.tag-filter-item.active {
  background: linear-gradient(135deg, #f472b6, #ec4899);
  border-color: #ec4899;
  color: #FFFFFF;
  transform: scale(1.05);
  box-shadow: 0 4rpx 12rpx rgba(236, 72, 153, 0.3);
}

.tag-filter-text {
  line-height: 1;
}

.tag-filter-result {
  padding: 12rpx 0;
  text-align: center;
}

.tag-filter-result-text {
  font-size: 22rpx;
  color: #94a3b8;
  font-weight: 500;
}

/* 日记卡片内的标签 */
.diary-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.diary-tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, #fef3f8, #fce7f3);
  border-radius: 16rpx;
  border: 1rpx solid rgba(236, 72, 153, 0.2);
}

.diary-tag-text {
  font-size: 20rpx;
  color: #ec4899;
  font-weight: 600;
  line-height: 1;
}

/* 置顶标记 */
.pinned-badge {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, #FFF9E6, #FFE4B5);
  border-radius: 20rpx;
  border: 2rpx solid #FFD700;
  margin-bottom: 8rpx;
}

.pinned-icon {
  font-size: 24rpx;
  line-height: 1;
}

.pinned-text {
  font-size: 20rpx;
  color: #D4A017;
  font-weight: bold;
  line-height: 1;
}
