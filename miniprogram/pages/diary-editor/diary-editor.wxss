.container {
  min-height: 100vh;
  background: #FFF5F5;
  display: flex;
  flex-direction: column;
}

.header {
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  background: rgba(255,255,255,0.9);
  backdrop-filter: blur(20rpx);
  border-bottom: 2rpx solid rgba(255, 228, 236, 0.5);
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  box-sizing: border-box;
}

.nav-left {
  position: absolute;
  left: 32rpx;
  display: flex;
  align-items: center;
  z-index: 101;
}

.nav-icon {
  font-size: 48rpx;
  color: #999999;
  font-weight: 300;
  line-height: 1;
}

.nav-title {
  width: 100%;
  text-align: center;
  font-size: 38rpx;
  font-weight: bold;
  color: #333333;
  font-family: serif;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  letter-spacing: 2rpx;
}

.nav-right {
  position: absolute;
  right: 32rpx;
  display: flex;
  justify-content: flex-end;
  z-index: 101;
}

.save-btn {
  width: 100%;
  max-width: 600rpx;
  padding: 28rpx 48rpx;
  background: linear-gradient(135deg, #FF69B4, #FFB6C1);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 60rpx;
  border: none;
  line-height: 1;
  box-shadow: 0 8rpx 24rpx rgba(255, 105, 180, 0.3);
}

.save-btn.disabled {
  background: #E8E8E8;
  color: #CCCCCC;
}

.content-scroll {
  flex: 1;
  padding: 32rpx;
  padding-bottom: 200rpx;
}

.section-label {
  display: block;
  font-size: 20rpx;
  color: #999999;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.mood-section {
  margin-bottom: 40rpx;
}

.mood-list {
  display: flex;
  gap: 16rpx;
  overflow-x: auto;
  padding-bottom: 8rpx;
}

.mood-item {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 24rpx;
  background: rgba(255,255,255,0.5);
  border-radius: 24rpx;
  min-width: 100rpx;
  transition: all 0.3s;
}

.mood-item.active {
  transform: scale(1.05);
  box-shadow: 0 4rpx 12rpx rgba(255, 105, 180, 0.15);
}

.mood-item.mood-heart.active {
  background: #FFE4EC;
}

.mood-item.mood-excited.active {
  background: #FFF8E1;
}

.mood-item.mood-healing.active {
  background: #E8F5E9;
}

.mood-item.mood-missing.active {
  background: #E3F2FD;
}

.mood-item.mood-crying.active {
  background: #F3E5F5;
}

.mood-icon {
  font-size: 32rpx;
  margin-bottom: 8rpx;
}

.mood-label {
  font-size: 20rpx;
  color: #999999;
  font-weight: bold;
}

.mood-item.active .mood-label {
  color: #333333;
}

.content-section {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 105, 180, 0.08);
}

.content-input {
  width: 100%;
  min-height: 300rpx;
  font-size: 32rpx;
  line-height: 1.6;
  color: #333333;
  background: transparent;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 20rpx;
  color: #CCCCCC;
  margin-top: 16rpx;
}

.image-section {
  margin-bottom: 40rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-tip {
  font-size: 20rpx;
  color: #FFB6C1;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.image-item {
  position: relative;
  aspect-ratio: 1;
  border-radius: 24rpx;
  overflow: hidden;
  background: #FFFFFF;
}

.image {
  width: 100%;
  height: 100%;
}

.video-item {
  position: relative;
}

.video-badge {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  padding: 4rpx 12rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #FFFFFF;
  font-size: 20rpx;
  border-radius: 12rpx;
  z-index: 10;
}

.delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  font-size: 28rpx;
  color: #FFFFFF;
  line-height: 1;
  font-weight: 300;
}

.image-add {
  aspect-ratio: 1;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.5);
  border: 3rpx dashed #FFE4EC;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #FFB6C1;
}

.add-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.add-text {
  font-size: 20rpx;
  font-weight: bold;
}

.tag-section {
  margin-bottom: 40rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 24rpx;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  padding: 16rpx 28rpx;
  background: #FFFFFF;
  color: #999999;
  font-size: 26rpx;
  font-weight: bold;
  border-radius: 24rpx;
  border: 2rpx solid #FFE4EC;
  transition: all 0.3s;
  cursor: pointer;
  min-height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tag-item.active {
  background: #F3E5F5;
  border-color: #D8BFD8;
  color: #9C27B0;
  box-shadow: 0 2rpx 8rpx rgba(156, 39, 176, 0.1);
  transform: scale(1.05);
}

.template-section {
  margin-bottom: 40rpx;
}

.template-list {
  display: flex;
  gap: 16rpx;
}

.template-item {
  padding: 16rpx 32rpx;
  background: #FFFFFF;
  color: #999999;
  font-size: 24rpx;
  font-weight: 500;
  border-radius: 24rpx;
  border: 2rpx solid #E8E8E8;
}

.template-item.active {
  background: #333333;
  border-color: #333333;
  color: #FFFFFF;
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}
