<view class="container" style="padding-top: {{totalNavHeight + 20}}px;">
  <view class="header" style="height: {{navHeight + navTop + 20}}px; padding-top: {{navTop}}px;">
    <view class="nav-left" bindtap="goBack" style="top: {{navTop}}px; height: {{navHeight + 20}}px;">
      <text class="nav-icon">‹</text>
    </view>
    <view class="nav-title" style="line-height: {{navHeight + 20}}px;">{{mode === 'edit' ? '编辑日记' : '写日记'}}</view>
    <view class="nav-right"></view>
  </view>

  <scroll-view class="content-scroll" scroll-y="true">
    <view class="mood-section">
      <text class="section-label">这一刻的情绪</text>
      <view class="mood-list">
        <view class="mood-item {{mood === item.id ? 'active' : ''}}" wx:for="{{moods}}" wx:key="id" bindtap="selectMood" data-id="{{item.id}}">
          <text class="mood-icon">{{item.icon}}</text>
          <text class="mood-label">{{item.label}}</text>
        </view>
      </view>
    </view>

    <view class="content-section">
      <view class="content-card">
        <textarea 
          class="content-input" 
          placeholder="记下这一刻的心动..." 
          placeholder-class="content-placeholder"
          value="{{content}}" 
          bindinput="onContentInput"
          maxlength="1000"
          auto-height
        ></textarea>
        <text class="char-count">{{content.length}}/1000</text>
      </view>
    </view>

    <view class="image-section">
      <view class="section-header">
        <text class="section-label">精选物料 ({{totalMediaCount}}/9)</text>
        <text class="section-tip">支持照片和视频</text>
      </view>
      <view class="image-grid">
        <view class="image-item" wx:for="{{images}}" wx:key="*this" wx:if="{{item.type !== 'video'}}">
          <image class="image" src="{{item.url || item}}" mode="aspectFill"></image>
          <view class="delete-btn" bindtap="deleteImage" data-index="{{index}}">
            <text class="delete-icon">×</text>
          </view>
        </view>
        <view class="image-item video-item" wx:for="{{images}}" wx:key="*this" wx:if="{{item.type === 'video'}}">
          <video class="image" src="{{item.url}}" controls="{{false}}" show-center-play-btn="{{true}}" object-fit="cover"></video>
          <view class="video-badge">视频</view>
          <view class="delete-btn" bindtap="deleteImage" data-index="{{index}}">
            <text class="delete-icon">×</text>
          </view>
        </view>
        <view class="image-add" wx:if="{{totalMediaCount < 9}}" bindtap="showChooseMedia">
          <text class="add-icon">📷</text>
          <text class="add-text">添加</text>
        </view>
      </view>
    </view>


    <view class="tag-section">
      <view class="tag-header">
        <text class="section-label">追星标签</text>
        <text class="tag-count">已选 {{selectedTagCount}}/3</text>
      </view>
      <view class="tag-list">
        <view class="tag-item {{item.selected ? 'active' : ''}} {{item.isCustom ? 'custom-tag' : ''}}" wx:for="{{tags}}" wx:key="name" bindtap="toggleTag" data-index="{{index}}">
          <text>{{item.name}}</text>
          <text wx:if="{{item.isCustom}}" class="custom-tag-delete" catchtap="deleteCustomTag" data-index="{{index}}">×</text>
        </view>
        <view class="tag-item add-tag-btn" bindtap="showAddCustomTag">
          <text class="add-tag-icon">+</text>
          <text>添加标签</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="footer" catchtap="">
    <view class="save-btn-wrap {{isSubmitting ? 'submitting' : ''}}">
      <button class="save-btn {{!canSave || isSubmitting ? 'disabled' : ''}}" catchtap="saveDiary" disabled="{{!canSave || isSubmitting}}">
        {{isSubmitting ? '保存中...' : (mode === 'edit' ? '发布' : '保存')}}
      </button>
    </view>
  </view>
</view>
