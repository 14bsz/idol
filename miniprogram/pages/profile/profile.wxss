.container {
  padding: 24rpx;
  padding-bottom: 120rpx;
}

.profile-header {
  background: rgba(255,255,255,0.8);
  backdrop-filter: blur(20rpx);
  border-radius: 32rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 105, 180, 0.1);
  border-top: 2rpx solid rgba(255,255,255,0.5);
}

.avatar-section {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar-wrapper {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: #FFE4EC;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 6rpx solid #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(255, 105, 180, 0.2);
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 60rpx;
}

.user-info {
  flex: 1;
}

.username {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  font-family: serif;
  color: #333333;
  margin-bottom: 8rpx;
}

.user-desc {
  color: #999999;
  font-size: 24rpx;
}

.menu-section {
  background: rgba(255,255,255,0.8);
  backdrop-filter: blur(20rpx);
  border-radius: 32rpx;
  padding: 16rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 105, 180, 0.1);
  border-top: 2rpx solid rgba(255,255,255,0.5);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-radius: 24rpx;
}

.menu-item:active {
  background: #FFF5F5;
}

.menu-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.menu-icon.blue {
  background: #E3F2FD;
}

.menu-icon.purple {
  background: #F3E5F5;
}

.menu-icon.pink {
  background: #FFE4EC;
}

.menu-icon text {
  font-size: 36rpx;
}

.menu-text {
  flex: 1;
}

.menu-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 4rpx;
}

.menu-desc {
  display: block;
  font-size: 20rpx;
  color: #999999;
}

.menu-arrow {
  font-size: 32rpx;
  color: #CCCCCC;
  font-weight: 300;
}

.action-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding-top: 40rpx;
}

.export-btn {
  width: 100%;
  padding: 28rpx;
  background: #333333;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 32rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.2);
}

.export-btn:active {
  background: #444444;
}

.version-text {
  color: #999999;
  font-size: 20rpx;
}

.login-section {
  margin-top: 32rpx;
}

.login-btn {
  width: 100%;
  padding: 28rpx;
  background: linear-gradient(135deg, #07C160, #06AD56);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 32rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.3);
}