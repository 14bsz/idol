<view class="container" style="padding: 24px; padding-bottom: 96px;">
  <!-- 未登录状态 -->
  <view wx:if="{{!isLoggedIn}}" class="guest-view">
    <!-- 页面标题 -->
    <view class="page-header" style="margin-bottom: 48rpx; text-align: center;">
      <view style="width: 120rpx; height: 120rpx; border-radius: 50%; background: linear-gradient(135deg, #fce4ec, #f3e5f5); display: inline-flex; align-items: center; justify-content: center; margin-bottom: 24rpx; box-shadow: 0 16rpx 48rpx -16rpx rgba(244, 114, 182, 0.3); overflow: hidden;">
        <image src="/images/avatar-placeholder.svg" style="width: 60rpx; height: 60rpx;" mode="aspectFit" />
      </view>
      <text style="font-size: 32rpx; font-weight: bold; color: #1e293b; display: block; margin-bottom: 8rpx;">个人中心</text>
      <text style="font-size: 24rpx; color: #94a3b8; display: block;">管理你的追星数据</text>
    </view>

    <!-- 功能预览 -->
    <view class="menu-preview" style="display: grid; gap: 24rpx; margin-bottom: 32rpx;">
      <view class="glass shadow-soft" style="padding: 30rpx 24rpx; border-radius: 24rpx; display: flex; align-items: center; gap: 24rpx; border-top: 1rpx solid rgba(255,255,255,0.4);">
        <view style="width: 80rpx; height: 80rpx; border-radius: 20rpx; background: #eff6ff; display: flex; align-items: center; justify-content: center;">
          <text style="font-size: 40rpx;">📊</text>
        </view>
        <view style="flex: 1;">
          <text style="font-size: 28rpx; font-weight: bold; color: #334155; display: block; margin-bottom: 8rpx;">追星月报</text>
          <text style="font-size: 22rpx; color: #94a3b8;">本月的心动指数分析</text>
        </view>
        <text style="color: #cbd5e1; font-size: 32rpx;">›</text>
      </view>

      <view class="glass shadow-soft" style="padding: 30rpx 24rpx; border-radius: 24rpx; display: flex; align-items: center; gap: 24rpx; border-top: 1rpx solid rgba(255,255,255,0.4);">
        <view style="width: 80rpx; height: 80rpx; border-radius: 20rpx; background: #faf5ff; display: flex; align-items: center; justify-content: center;">
          <text style="font-size: 40rpx;">📜</text>
        </view>
        <view style="flex: 1;">
          <text style="font-size: 28rpx; font-weight: bold; color: #334155; display: block; margin-bottom: 8rpx;">时光轴</text>
          <text style="font-size: 22rpx; color: #94a3b8;">回看一路走来的心路历程</text>
        </view>
        <text style="color: #cbd5e1; font-size: 32rpx;">›</text>
      </view>

      <view class="glass shadow-soft" style="padding: 30rpx 24rpx; border-radius: 24rpx; display: flex; align-items: center; gap: 24rpx; border-top: 1rpx solid rgba(255,255,255,0.4);">
        <view style="width: 80rpx; height: 80rpx; border-radius: 20rpx; background: #fdf2f8; display: flex; align-items: center; justify-content: center;">
          <text style="font-size: 40rpx;">📅</text>
        </view>
        <view style="flex: 1;">
          <text style="font-size: 28rpx; font-weight: bold; color: #334155; display: block; margin-bottom: 8rpx;">日程提醒</text>
          <text style="font-size: 22rpx; color: #94a3b8;">不再错过任何重要的日子</text>
        </view>
        <text style="color: #cbd5e1; font-size: 32rpx;">›</text>
      </view>
    </view>

    <!-- 登录提示 -->
    <view style="display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center;">
      <text style="font-size: 24rpx; color: #94a3b8; margin-bottom: 24rpx;">登录后查看你的专属数据</text>
      <view class="login-btn" bindtap="goToLogin" hover-class="button-hover" style="padding: 24rpx 64rpx; border-radius: 9999rpx; background: linear-gradient(135deg, #f472b6, #ec4899); color: white; font-size: 28rpx; font-weight: bold; box-shadow: 0 12rpx 32rpx -12rpx rgba(236, 72, 153, 0.5);">
        立即登录
      </view>
    </view>
  </view>

  <!-- 已登录状态 -->
  <view wx:else>
    <view class="profile-header" style="display: flex; align-items: center; gap: 24rpx; padding: 24rpx; background: white; border-radius: 32rpx; box-shadow: 0 4rpx 24rpx -8rpx rgba(0,0,0,0.05);">
      <view class="profile-avatar" bindtap="chooseAvatar" style="width: 100rpx; height: 100rpx; border-radius: 50%; background: #fce4ec; display: flex; align-items: center; justify-content: center; border: 4rpx solid white; box-shadow: 0 10rpx 30rpx -5rpx rgba(0,0,0,0.05); overflow: hidden;">
        <text wx:if="{{!resolvedAvatarUrl}}" style="font-size: 40px; color: #f472b6;">👤</text>
        <image wx:else src="{{resolvedAvatarUrl}}" style="width: 100%; height: 100%;" mode="aspectFill"></image>
      </view>
      <!-- 使用微信头像：open-type="chooseAvatar"，选完后通过 bindchooseavatar 回调拿到真实头像 -->
      <button
        wx:if="{{showWechatAvatarBtn}}"
        open-type="chooseAvatar"
        bindchooseavatar="onChooseWechatAvatar"
        style="position:fixed;top:0;left:0;width:100%;height:100%;opacity:0;z-index:999;margin:0;padding:0;background:transparent;border:none;"
      ></button>
      <view class="profile-info" style="flex: 1;" bindtap="editNickname">
        <text class="profile-name title-serif" style="font-size: 24px; font-weight: bold;">{{userInfo ? userInfo.nickname : '追星女孩'}}</text>
        <text class="profile-desc" style="font-size: 12px; color: #94a3b8; margin-top: 4rpx; display: block;">✨ 正在记录心动时光</text>
      </view>
    </view>

    <view class="menu-list" style="display: grid; grid-template-columns: 1fr; gap: 24rpx; margin-top: 40rpx;">
      <block wx:for="{{menuItems}}" wx:key="title">
        <view class="menu-item glass shadow-soft" bindtap="onMenuItemClick" data-index="{{index}}" style="padding: 30rpx 24rpx; border-radius: 24rpx; display: flex; align-items: center; gap: 24rpx; border-top: 1rpx solid rgba(255,255,255,0.4); background: white;">
          <view class="menu-icon" style="width: 80rpx; height: 80rpx; border-radius: 20rpx; background: {{item.bgColor}}; display: flex; align-items: center; justify-content: center;">
            <text style="font-size: 24px;">{{item.icon}}</text>
          </view>
          <view class="menu-text" style="flex: 1;">
            <text class="menu-title" style="font-size: 16px; font-weight: bold; color: #334155; display: block; margin-bottom: 8rpx;">{{item.title}}</text>
            <text class="menu-desc" style="font-size: 12px; color: #94a3b8;">{{item.desc}}</text>
          </view>
          <text class="menu-arrow" style="color: #cbd5e1; font-size: 20px;">›</text>
        </view>
      </block>
    </view>

    <view class="footer-section" style="display: flex; flex-direction: column; align-items: center; gap: 24rpx; margin-top: 60rpx; padding-top: 40rpx;">
      <view class="logout-btn" bindtap="onLogout" style="width: 100%; height: 88rpx; line-height: 88rpx; border-radius: 44rpx; background: #fef2f2; color: #dc2626; font-size: 16px; font-weight: bold; text-align: center; border: 1rpx solid #fecaca;">
        🚪 退出登录
      </view>
      <text class="footer-text" style="font-size: 12px; color: #cbd5e1;">爱豆时光日记 v1.0.0 • 记录纯粹的爱</text>
    </view>
  </view>
</view>
