.container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  backdrop-filter: blur(12px);
}

.content {
  position: relative;
  z-index: 10;
  width: 100%;
  max-width: 750rpx;
  margin: 0 auto;
  padding: 40rpx 24rpx 32rpx;
  height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  box-sizing: border-box;
}

.header {
  display: flex;
  justify-content: flex-end;
  padding-right: 8rpx;
  margin-bottom: 24rpx;
}

.close-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(20px);
}

.card-container {
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 32rpx;
  padding: 0;
}

.card {
  width: 100%;
  min-height: 900rpx;
  border-radius: 36rpx;
  padding: 36rpx;
  box-shadow: 0 24rpx 72rpx -24rpx rgba(0, 0, 0, 0.35);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  position: relative;
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  box-sizing: border-box;
}

.bg-white {
  background: #ffffff;
}

.bg-gradient {
  background: linear-gradient(135deg, #FFF5F7 0%, #FFF0F6 50%, #F0F7FF 100%);
}

.bg-vintage {
  background: #f4f1ea;
}

.bg-dark {
  background: #0f172a;
}

.text-slate-800 {
  color: #1e293b;
}

.text-slate-700 {
  color: #334155;
}

.text-vintage-text {
  color: #4a4a4a;
}

.text-white {
  color: #ffffff;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
  z-index: 10;
  margin-bottom: 8rpx;
}

.header-sparkles {
  width: 40rpx;
  height: 40rpx;
  opacity: 0.4;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.66);
  overflow: hidden;
  box-shadow: 0 10rpx 28rpx -12rpx rgba(0, 0, 0, 0.16);
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.header-info {
  display: flex;
  flex-direction: column;
}

.with-text {
  font-size: 18rpx;
  opacity: 0.56;
  letter-spacing: 0.28em;
  font-weight: bold;
  display: block;
}

.name-text {
  font-size: 30rpx;
  font-style: italic;
  font-weight: bold;
  letter-spacing: 0.02em;
}

.card-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 28rpx 0 20rpx;
  position: relative;
  z-index: 10;
  min-height: 0;
}

.card-image {
  width: 100%;
  height: 460rpx;
  min-height: 460rpx;
  border-radius: 28rpx;
  overflow: hidden;
  margin-bottom: 28rpx;
  box-shadow: 0 18rpx 42rpx -18rpx rgba(0, 0, 0, 0.22);
  background: #f8fafc;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.image-img {
  width: 100%;
  height: 100%;
  display: block;
}

.image-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 140rpx;
  background: linear-gradient(180deg, rgba(15, 23, 42, 0) 0%, rgba(15, 23, 42, 0.18) 100%);
}

.image-badge {
  position: absolute;
  left: 20rpx;
  top: 20rpx;
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.82);
  color: #1e293b;
  font-size: 18rpx;
  line-height: 48rpx;
  font-weight: 700;
  letter-spacing: 0.2em;
  backdrop-filter: blur(12rpx);
}

.content-inner {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  flex: 1;
  min-height: 0;
}

.content-meta {
  display: flex;
  justify-content: center;
}

.content-tag {
  height: 44rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.42);
  font-size: 18rpx;
  line-height: 44rpx;
  font-weight: 700;
  letter-spacing: 0.16em;
  opacity: 0.86;
}

.divider {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.divider-line {
  flex: 1;
  height: 2rpx;
  background: currentColor;
  opacity: 0.1;
}

.content-text {
  text-align: center;
  font-style: italic;
  line-height: 1.8;
  font-size: 28rpx;
  font-weight: 600;
  word-break: break-all;
  white-space: normal;
  display: block;
  width: 100%;
  letter-spacing: 0.02em;
}

.text-serif {
  font-size: 38rpx;
  font-family: Georgia, 'Times New Roman', Times, serif;
  line-height: 1.72;
}

.card-footer {
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  position: relative;
  z-index: 10;
  padding-top: 12rpx;
}

.date-text {
  font-size: 22rpx;
  font-family: 'Courier New', monospace;
  letter-spacing: 0.18em;
  opacity: 0.52;
}

.brand-text {
  font-size: 18rpx;
  letter-spacing: 0.32em;
  font-weight: 900;
  opacity: 0.34;
  margin-top: 10rpx;
}

.deco-bg {
  position: absolute;
  top: 0;
  right: 0;
  width: 256rpx;
  height: 256rpx;
  background: rgba(252, 228, 236, 0.3);
  border-radius: 50%;
  filter: blur(48rpx);
  transform: translate(80rpx, -80rpx);
}

.template-accent {
  position: absolute;
  pointer-events: none;
  z-index: 1;
}

.template-accent-top {
  top: -32rpx;
  right: -12rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  opacity: 0;
}

.template-accent-bottom {
  left: -36rpx;
  bottom: 120rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  opacity: 0;
}

.controls {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  width: 100%;
}

.template-list {
  width: 100%;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.template-btn {
  width: 100%;
  height: 76rpx;
  padding: 0 24rpx;
  border-radius: 34rpx;
  font-size: 22rpx;
  line-height: 76rpx;
  font-weight: 700;
  transition: all 0.3s ease;
  border: 2rpx solid rgba(255, 255, 255, 0.16);
  background: rgba(255, 255, 255, 0.12);
  color: rgba(255, 255, 255, 0.72);
  box-sizing: border-box;
  text-align: center;
}

.template-btn.active {
  background: #ffffff;
  color: #1e293b;
  border-color: #ffffff;
  box-shadow: 0 16rpx 32rpx -16rpx rgba(0, 0, 0, 0.22);
  transform: scale(1.02);
}

.save-btn {
  width: 100%;
  height: 92rpx;
  margin: 0;
  padding: 0 24rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #ffffff 0%, #fff2f7 100%);
  color: #1e293b;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 18rpx 36rpx -18rpx rgba(0, 0, 0, 0.32);
  box-sizing: border-box;
  border: none;
}

.save-btn::after {
  border: none;
}

.save-btn.disabled {
  opacity: 0.5;
}

.save-icon {
  width: 34rpx;
  height: 34rpx;
  flex-shrink: 0;
}

.save-text {
  font-size: 26rpx;
  font-weight: 700;
  color: #1e293b;
  line-height: 1;
  letter-spacing: 0.02em;
}

.template-minimal-korean {
  box-shadow: 0 24rpx 72rpx -24rpx rgba(148, 163, 184, 0.36);
}

.template-minimal-korean .card-image {
  border: 2rpx solid rgba(255, 255, 255, 0.72);
}

.template-minimal-korean .image-badge {
  background: rgba(255, 255, 255, 0.88);
  color: #475569;
}

.template-minimal-korean .content-tag {
  background: rgba(255, 255, 255, 0.58);
  color: #64748b;
}

.template-minimal-korean .content-text {
  font-weight: 500;
  letter-spacing: 0.04em;
}

.template-minimal-korean .template-accent-top {
  opacity: 1;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.85) 0%, rgba(255, 255, 255, 0) 72%);
}

.template-minimal-korean .template-accent-bottom {
  opacity: 1;
  background: radial-gradient(circle, rgba(236, 253, 245, 0.65) 0%, rgba(236, 253, 245, 0) 70%);
}

.template-dreamy-gradient {
  box-shadow: 0 28rpx 86rpx -28rpx rgba(244, 114, 182, 0.34);
}

.template-dreamy-gradient .card-image {
  border-radius: 32rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 20rpx 50rpx -22rpx rgba(236, 72, 153, 0.28);
}

.template-dreamy-gradient .image-overlay {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0) 0%, rgba(244, 114, 182, 0.2) 100%);
}

.template-dreamy-gradient .image-badge {
  background: rgba(255, 240, 246, 0.92);
  color: #be185d;
  box-shadow: 0 10rpx 24rpx -12rpx rgba(236, 72, 153, 0.26);
}

.template-dreamy-gradient .content-tag {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.72) 0%, rgba(255, 228, 236, 0.88) 100%);
  color: #be185d;
}

.template-dreamy-gradient .divider-line {
  opacity: 0.16;
}

.template-dreamy-gradient .content-text {
  font-weight: 600;
  text-shadow: 0 6rpx 18rpx rgba(255, 255, 255, 0.35);
}

.template-dreamy-gradient .template-accent-top {
  opacity: 1;
  background: radial-gradient(circle, rgba(251, 207, 232, 0.92) 0%, rgba(251, 207, 232, 0) 72%);
  filter: blur(10rpx);
}

.template-dreamy-gradient .template-accent-bottom {
  opacity: 1;
  background: radial-gradient(circle, rgba(219, 234, 254, 0.8) 0%, rgba(219, 234, 254, 0) 72%);
  filter: blur(12rpx);
}

.template-vintage-paper {
  border: 2rpx solid rgba(120, 96, 64, 0.16);
  box-shadow: 0 24rpx 72rpx -30rpx rgba(92, 71, 47, 0.34);
}

.template-vintage-paper .header-sparkles {
  opacity: 0.28;
}

.template-vintage-paper .avatar {
  border-color: rgba(120, 96, 64, 0.2);
  box-shadow: none;
}

.template-vintage-paper .with-text {
  opacity: 0.72;
  letter-spacing: 0.18em;
}

.template-vintage-paper .name-text {
  font-style: normal;
  letter-spacing: 0.08em;
}

.template-vintage-paper .card-image {
  height: 430rpx;
  min-height: 430rpx;
  border-radius: 12rpx;
  border: 2rpx solid rgba(120, 96, 64, 0.18);
  box-shadow: none;
  filter: saturate(0.82) contrast(0.94);
}

.template-vintage-paper .image-overlay {
  background: linear-gradient(180deg, rgba(91, 73, 49, 0) 0%, rgba(91, 73, 49, 0.14) 100%);
}

.template-vintage-paper .image-badge {
  background: rgba(111, 88, 61, 0.9);
  color: #f8f1e5;
  letter-spacing: 0.14em;
}

.template-vintage-paper .content-tag {
  background: rgba(215, 199, 174, 0.78);
  color: #6b4f32;
}

.template-vintage-paper .divider-line {
  height: 1rpx;
  opacity: 0.22;
}

.template-vintage-paper .content-text {
  font-style: normal;
  font-weight: 500;
  line-height: 1.72;
  letter-spacing: 0.06em;
}

.template-vintage-paper .date-text,
.template-vintage-paper .brand-text {
  opacity: 0.58;
}

.template-vintage-paper .template-accent-top {
  opacity: 1;
  background: radial-gradient(circle, rgba(215, 199, 174, 0.48) 0%, rgba(215, 199, 174, 0) 72%);
}

.template-vintage-paper .template-accent-bottom {
  opacity: 1;
  background: radial-gradient(circle, rgba(190, 174, 151, 0.4) 0%, rgba(190, 174, 151, 0) 72%);
}

.template-dark-idol {
  border: 1rpx solid rgba(250, 204, 21, 0.18);
  box-shadow: 0 30rpx 90rpx -28rpx rgba(15, 23, 42, 0.78);
  background: linear-gradient(160deg, #0f172a 0%, #111827 42%, #1e1b4b 100%);
}

.template-dark-idol .header-sparkles {
  opacity: 0.68;
}

.template-dark-idol .avatar {
  border-color: rgba(250, 204, 21, 0.36);
  box-shadow: 0 10rpx 24rpx -12rpx rgba(250, 204, 21, 0.3);
}

.template-dark-idol .with-text {
  color: rgba(250, 204, 21, 0.76);
  opacity: 1;
}

.template-dark-idol .name-text {
  letter-spacing: 0.08em;
}

.template-dark-idol .card-image {
  border: 2rpx solid rgba(250, 204, 21, 0.28);
  box-shadow: 0 18rpx 42rpx -18rpx rgba(0, 0, 0, 0.56);
}

.template-dark-idol .image-overlay {
  background: linear-gradient(180deg, rgba(15, 23, 42, 0) 0%, rgba(15, 23, 42, 0.44) 100%);
}

.template-dark-idol .image-badge {
  background: rgba(15, 23, 42, 0.84);
  color: #facc15;
  border: 1rpx solid rgba(250, 204, 21, 0.28);
}

.template-dark-idol .content-tag {
  background: rgba(250, 204, 21, 0.12);
  color: #fde68a;
  border: 1rpx solid rgba(250, 204, 21, 0.18);
}

.template-dark-idol .divider-line {
  opacity: 0.2;
}

.template-dark-idol .content-text {
  font-weight: 700;
  line-height: 1.74;
  text-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.4);
}

.template-dark-idol .date-text,
.template-dark-idol .brand-text {
  color: rgba(255, 255, 255, 0.76);
  opacity: 0.74;
}

.template-dark-idol .template-accent-top {
  opacity: 1;
  background: radial-gradient(circle, rgba(250, 204, 21, 0.2) 0%, rgba(250, 204, 21, 0) 72%);
}

.template-dark-idol .template-accent-bottom {
  opacity: 1;
  background: radial-gradient(circle, rgba(147, 51, 234, 0.18) 0%, rgba(147, 51, 234, 0) 72%);
}

.toast {
  position: fixed;
  bottom: 96rpx;
  left: 50%;
  transform: translateX(-50%);
  padding: 24rpx 48rpx;
  background: #ffffff;
  border-radius: 9999rpx;
  box-shadow: 0 16rpx 48rpx -16rpx rgba(0, 0, 0, 0.2);
  display: flex;
  align-items: center;
  gap: 24rpx;
  z-index: 2000;
}

.toast-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #dcfce7;
  display: flex;
  align-items: center;
  justify-content: center;
}

.toast-text {
  font-size: 24rpx;
  font-weight: bold;
  color: #1e293b;
}

.save-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 1080px;
  height: 1440px;
  opacity: 0;
  pointer-events: none;
}
