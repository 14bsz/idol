<view class="container" style="padding: 24px; padding-bottom: {{isManageMode ? '240px' : '96px'}};">
  <!-- WXS辅助函数 -->
  <wxs module="utils">
    var isSelected = function(selectedIds, id) {
      if (!selectedIds || !id) return false;
      for (var i = 0; i < selectedIds.length; i++) {
        if (selectedIds[i] == id) {
          return true;
        }
      }
      return false;
    };
    module.exports = {
      isSelected: isSelected
    };
  </wxs>
  
  <!-- 未登录状态 -->
  <view wx:if="{{!isLoggedIn}}" class="guest-view">
    <!-- 页面标题 -->
    <view class="page-header" style="margin-bottom: 48rpx;">
      <text class="page-title title-serif" style="font-size: 30px; font-weight: bold; display: block;">专属收藏夹</text>
      <text class="page-subtitle" style="font-size: 10px; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.1em; font-weight: bold; margin-top: 4rpx; display: block;">Starlight collection</text>
    </view>

    <!-- 功能介绍卡片 -->
    <view class="glass shadow-soft" style="padding: 48rpx; border-radius: 48rpx; margin-bottom: 32rpx; border-top: 2rpx solid rgba(255,255,255,0.4);">
      <view style="text-align: center; margin-bottom: 32rpx;">
        <view style="width: 100rpx; height: 100rpx; border-radius: 50%; background: linear-gradient(135deg, #fce4ec, #f3e5f5); display: inline-flex; align-items: center; justify-content: center; margin-bottom: 24rpx;">
          <text style="font-size: 48px;">📷</text>
        </view>
        <text style="font-size: 28rpx; font-weight: bold; color: #1e293b; display: block; margin-bottom: 16rpx;">珍藏爱豆的美好瞬间</text>
        <text style="font-size: 24rpx; color: #64748b; line-height: 1.6; display: block;">默认分类随手整理，也支持自定义你的专属标签夹</text>
      </view>

      <!-- 分类展示 -->
      <view style="display: grid; grid-template-columns: 1fr 1fr; gap: 24rpx; margin-bottom: 32rpx;">
        <view style="padding: 32rpx; background: rgba(255,255,255,0.6); border-radius: 24rpx; text-align: center;">
          <text style="font-size: 40rpx; display: block; margin-bottom: 12rpx;">✨</text>
          <text style="font-size: 24rpx; font-weight: bold; color: #334155; display: block;">神图</text>
        </view>
        <view style="padding: 32rpx; background: rgba(255,255,255,0.6); border-radius: 24rpx; text-align: center;">
          <text style="font-size: 40rpx; display: block; margin-bottom: 12rpx;">🎴</text>
          <text style="font-size: 24rpx; font-weight: bold; color: #334155; display: block;">小卡</text>
        </view>
        <view style="padding: 32rpx; background: rgba(255,255,255,0.6); border-radius: 24rpx; text-align: center;">
          <text style="font-size: 40rpx; display: block; margin-bottom: 12rpx;">📦</text>
          <text style="font-size: 24rpx; font-weight: bold; color: #334155; display: block;">物料</text>
        </view>
        <view style="padding: 32rpx; background: rgba(255,255,255,0.6); border-radius: 24rpx; text-align: center;">
          <text style="font-size: 40rpx; display: block; margin-bottom: 12rpx;">💬</text>
          <text style="font-size: 24rpx; font-weight: bold; color: #334155; display: block;">语录</text>
        </view>
        <view style="padding: 32rpx; background: rgba(255,255,255,0.6); border-radius: 24rpx; text-align: center; grid-column: span 2;">
          <text style="font-size: 40rpx; display: block; margin-bottom: 12rpx;">🎤</text>
          <text style="font-size: 24rpx; font-weight: bold; color: #334155; display: block;">线下活动</text>
          <text style="font-size: 20rpx; color: #64748b; display: block; margin-top: 8rpx;">演唱会 · 见面会 · 音乐节</text>
        </view>
      </view>

      <!-- 特点说明 -->
      <view style="background: rgba(236, 72, 153, 0.05); padding: 24rpx; border-radius: 24rpx; border: 2rpx dashed rgba(236, 72, 153, 0.2);">
        <text style="font-size: 20rpx; color: #64748b; line-height: 1.8; display: block;">💡 支持添加标签和笔记，让每一份收藏都更有意义</text>
      </view>
    </view>

    <!-- 温馨提示 -->
    <view style="display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center;">
      <text style="font-size: 24rpx; color: #94a3b8; line-height: 1.8;">💡 登录后可以收藏你的专属回忆<br/>你可以先浏览其他功能哦</text>
    </view>
  </view>

  <!-- 已登录状态 -->
  <view wx:else>
    <view class="page-header" style="display: flex; align-items: center; justify-content: space-between;">
      <view class="header-text">
        <text class="page-title title-serif" style="font-size: 30px; font-weight: bold;">专属收藏夹</text>
        <text class="page-subtitle" style="font-size: 10px; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.1em; font-weight: bold; margin-top: 4rpx; display: block;">Starlight collection</text>
      </view>
      <view style="display: flex; gap: 16rpx; align-items: center;">
        <!-- 管理按钮 -->
        <view wx:if="{{!isManageMode}}" bindtap="enterManageMode" class="manage-btn" style="padding: 16rpx 32rpx; background: rgba(244, 114, 182, 0.1); border-radius: 48rpx; display: flex; align-items: center; gap: 8rpx;">
          <text style="font-size: 24rpx; color: #f472b6; font-weight: 500;">管理</text>
        </view>
        <!-- 取消按钮(管理模式下) -->
        <view wx:else bindtap="exitManageMode" class="cancel-btn" style="padding: 16rpx 32rpx; background: rgba(100, 116, 139, 0.1); border-radius: 48rpx; display: flex; align-items: center; gap: 8rpx;">
          <text style="font-size: 24rpx; color: #64748b; font-weight: 500;">取消</text>
        </view>
        <!-- 添加按钮 -->
        <view bindtap="onAddCollection" class="add-btn">
          <text class="add-text">+</text>
        </view>
      </view>
    </view>

    <view class="category-tabs" style="display: flex; align-items: center; gap: 12rpx; margin-top: 24rpx; overflow-x: auto; padding-bottom: 8rpx;">
      <block wx:for="{{categories}}" wx:key="*this">
        <view 
          class="tab-item {{selectedCategory === item ? 'active' : ''}}" 
          bindtap="onCategorySelect" 
          data-category="{{item}}"
        >
          {{item}}
        </view>
      </block>
    </view>

    <view class="collection-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; margin-top: 24rpx;">
      <block wx:for="{{filteredCollections}}" wx:key="id">
        <view class="collection-item" bindtap="{{isManageMode ? 'onToggleSelect' : 'onItemClick'}}" data-item="{{item}}" data-id="{{item.id}}" style="position: relative; aspect-ratio: 1/1; border-radius: 32rpx; overflow: hidden; border: 1rpx solid white;">
          <image src="{{item.imageUrl}}" mode="aspectFill" style="width: 100%; height: 100%;" />
          
          <!-- 管理模式下的选择框 -->
          <view wx:if="{{isManageMode}}" class="select-overlay" style="position: absolute; inset: 0; background: {{utils.isSelected(selectedIds, item.id) ? 'rgba(244, 114, 182, 0.3)' : 'rgba(0,0,0,0.2)'}}; display: flex; align-items: flex-start; justify-content: flex-end; padding: 16rpx;">
            <view class="checkbox" style="width: 48rpx; height: 48rpx; border-radius: 50%; background: {{utils.isSelected(selectedIds, item.id) ? '#f472b6' : 'rgba(255,255,255,0.8)'}}; border: 2rpx solid {{utils.isSelected(selectedIds, item.id) ? '#f472b6' : '#e2e8f0'}}; display: flex; align-items: center; justify-content: center;">
              <text wx:if="{{utils.isSelected(selectedIds, item.id)}}" style="color: white; font-size: 32rpx; font-weight: bold;">✓</text>
            </view>
          </view>
          
          <!-- 非管理模式下的悬浮信息 -->
          <view wx:else class="item-overlay" style="position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, transparent 50%, transparent 100%); opacity: 0; display: flex; flex-direction: column; justify-content: flex-end; padding: 16rpx;">
            <text class="item-category" style="font-size: 10px; color: rgba(255,255,255,0.7); font-weight: bold; text-transform: uppercase; letter-spacing: 0.2em; margin-bottom: 4rpx;">{{item.category}}</text>
            <view class="item-bottom" style="display: flex; align-items: center; justify-content: space-between;">
              <text class="item-date" style="font-size: 10px; color: white; font-family: 'Courier New', monospace;">{{item.createdAt}}</text>
              <view class="item-actions" style="display: flex; gap: 8rpx;">
                <view class="action-heart" style="width: 24rpx; height: 24rpx; border-radius: 50%; background: white; display: flex; align-items: center; justify-content: center; color: #ec4899;">
                  <text style="font-size: 12px;">💗</text>
                </view>
              </view>
            </view>
          </view>
          
          <view wx:if="{{item.notes && !isManageMode}}" class="note-dot" style="position: absolute; top: 16rpx; left: 16rpx; width: 8rpx; height: 8rpx; border-radius: 50%; background: #f472b6; box-shadow: 0 0 0 8rpx rgba(244,114,182,0.2);" />
        </view>
      </block>

      <view wx:if="{{filteredCollections.length === 0}}" class="empty-state" style="grid-column: span 2; padding: 120rpx 40rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center;">
        <view class="empty-icon-wrapper" style="width: 120rpx; height: 120rpx; border-radius: 50%; background: #fff5f7; display: flex; align-items: center; justify-content: center; margin-bottom: 32rpx;">
          <text style="font-size: 60rpx;">🖼️</text>
        </view>
        <text class="empty-text-main" style="font-size: 32rpx; font-weight: bold; color: #1e293b; margin-bottom: 12rpx;">该分类下还没有收藏哦。</text>
        <text class="empty-text-tip" style="font-size: 24rpx; color: #94a3b8; line-height: 1.6; max-width: 480rpx;">点击右上角+号，把你珍藏的图片按自定义分类慢慢归档吧</text>
      </view>
    </view>

    <!-- 批量操作底部栏 -->
    <view wx:if="{{isManageMode}}" class="batch-action-bar" style="position: fixed; bottom: 160rpx; left: 0; right: 0; background: white; padding: 24rpx 32rpx; box-shadow: 0 -2rpx 20rpx rgba(0,0,0,0.08); display: flex; align-items: center; justify-content: space-between; z-index: 100; border-top: 1rpx solid #f1f5f9; border-radius: 32rpx 32rpx 0 0;">
      <view style="display: flex; align-items: center; gap: 24rpx;">
        <view bindtap="onToggleSelectAll" style="display: flex; align-items: center; gap: 12rpx; padding: 8rpx;">
          <view style="width: 40rpx; height: 40rpx; border-radius: 50%; border: 2rpx solid {{isAllSelected ? '#f472b6' : '#cbd5e1'}}; background: {{isAllSelected ? '#f472b6' : 'white'}}; display: flex; align-items: center; justify-content: center; transition: all 0.2s;">
            <text wx:if="{{isAllSelected}}" style="color: white; font-size: 28rpx; font-weight: bold;">✓</text>
          </view>
          <text style="font-size: 28rpx; color: #334155; font-weight: 500;">全选</text>
        </view>
        <text style="font-size: 26rpx; color: #64748b;">已选 {{selectedIds.length}} 项</text>
      </view>
      <view 
        bindtap="onBatchDelete" 
        style="padding: 24rpx 48rpx; background: {{selectedIds.length > 0 ? 'linear-gradient(135deg, #f87171, #dc2626)' : '#f1f5f9'}}; color: {{selectedIds.length > 0 ? 'white' : '#94a3b8'}}; border-radius: 48rpx; font-size: 30rpx; font-weight: 600; box-shadow: {{selectedIds.length > 0 ? '0 4rpx 12rpx rgba(220, 38, 38, 0.3)' : 'none'}}; transition: all 0.3s;"
      >
        删除{{selectedIds.length > 0 ? ' (' + selectedIds.length + ')' : ''}}
      </view>
    </view>
  </view>

  <!-- 详情弹窗 -->
  <view wx:if="{{showDetail}}" class="detail-mask" bindtap="closeDetail">
    <view class="detail-container">
      <view class="detail-content" catchtap="">
        <view class="detail-image-wrapper">
          <image src="{{currentDetail.imageUrl}}" mode="aspectFill" class="detail-image" />
          <view class="detail-badge">
            <text>{{currentDetail.category}}</text>
          </view>
        </view>
        
        <scroll-view scroll-y class="detail-info">
          <view class="detail-header">
            <view class="detail-date-box">
              <text class="date-label">创建时间</text>
              <text class="date-value">{{currentDetail.createdAt}}</text>
            </view>
            <view wx:if="{{currentDetail.eventDate}}" class="detail-date-box event-date-box">
              <text class="date-label">活动日期</text>
              <text class="date-value">{{currentDetail.eventDate}}</text>
            </view>
          </view>

          <view wx:if="{{currentDetail.tagList && currentDetail.tagList.length > 0}}" class="detail-tags">
            <view class="section-title">相关标签</view>
            <view class="tags-list">
              <text class="tag-chip" wx:for="{{currentDetail.tagList}}" wx:key="*this">{{item}}</text>
            </view>
          </view>

          <view wx:if="{{currentDetail.notes}}" class="detail-notes">
            <view class="section-title">心动笔记</view>
            <view class="notes-content">
              <text class="notes-text">{{currentDetail.notes}}</text>
            </view>
          </view>

        </scroll-view>
      </view>
      <view class="detail-close-area" catchtap="closeDetail">
        <view class="close-icon-btn"></view>
      </view>
    </view>
  </view>
</view>
