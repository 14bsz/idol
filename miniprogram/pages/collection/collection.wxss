.detail-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: fadeIn 0.3s ease;
}

.detail-container {
  width: 640rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: slideUp 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.detail-content {
  width: 100%;
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.2);
}

.detail-image-wrapper {
  position: relative;
  width: 100%;
  height: 640rpx;
  background: transparent;
}

.detail-image {
  width: 100%;
  height: 100%;
}

.detail-badge {
  position: absolute;
  top: 24rpx;
  left: 24rpx;
  padding: 6rpx 20rpx;
  background: rgba(244, 114, 182, 0.9);
  backdrop-filter: blur(8rpx);
  border-radius: 12rpx;
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(244, 114, 182, 0.3);
}

.detail-info {
  max-height: 400rpx;
  padding: 40rpx 32rpx;
  box-sizing: border-box;
}

.detail-header {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.detail-date-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.date-label {
  font-size: 26rpx;
  color: #64748b;
}

.date-value {
  font-size: 26rpx;
  color: #334155;
  font-family: 'Courier New', monospace;
  font-weight: 500;
}

.event-date-box .date-label {
  color: #f472b6;
}

.event-date-box .date-value {
  color: #ec4899;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1e293b;
  margin-bottom: 16rpx;
  position: relative;
  padding-left: 16rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 24rpx;
  background: #f472b6;
  border-radius: 4rpx;
}

.detail-tags {
  margin-bottom: 32rpx;
}

.tags-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-chip {
  padding: 8rpx 24rpx;
  background: #fff0f5;
  color: #ec4899;
  font-size: 24rpx;
  border-radius: 32rpx;
  font-weight: 500;
}

.detail-notes {
  margin-bottom: 16rpx;
}

.notes-content {
  background: #f8fafc;
  padding: 24rpx;
  border-radius: 16rpx;
}

.notes-text {
  font-size: 28rpx;
  color: #475569;
  line-height: 1.6;
  white-space: pre-wrap;
}

.detail-close-area {
  margin-top: 48rpx;
  display: flex;
  justify-content: center;
}

.close-icon-btn {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.8);
  background: rgba(0, 0, 0, 0.2);
  box-sizing: border-box;
}

.close-icon-btn::before,
.close-icon-btn::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 36rpx;
  height: 3rpx;
  background-color: #FFFFFF;
  border-radius: 4rpx;
}

.close-icon-btn::before {
  transform: translate(-50%, -50%) rotate(45deg);
}

.close-icon-btn::after {
  transform: translate(-50%, -50%) rotate(-45deg);
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from { transform: translateY(40rpx) scale(0.95); opacity: 0; }
  to { transform: translateY(0) scale(1); opacity: 1; }
}
