.container {
  padding: 24rpx;
  padding-bottom: 160rpx;
  box-sizing: border-box;
}

.header {
  margin-bottom: 32rpx;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  font-family: serif;
  color: #333333;
  margin-bottom: 8rpx;
}

.page-subtitle {
  color: #999999;
  font-size: 24rpx;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  font-weight: bold;
}

.category-tabs {
  display: flex;
  gap: 12rpx;
  margin-bottom: 32rpx;
  overflow-x: auto;
  padding-bottom: 8rpx;
}

.tab-item {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 2rpx solid #e2e8f0;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #64748b;
  font-weight: 500;
  transition: all 0.2s ease;
  white-space: nowrap;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.tab-item.active {
  background: linear-gradient(135deg, #f472b6, #ec4899);
  border-color: transparent;
  color: #FFFFFF;
  transform: scale(1);
  box-shadow: 0 4rpx 12rpx rgba(244, 114, 182, 0.3), 0 2rpx 4rpx rgba(236, 72, 153, 0.1) inset;
  font-weight: 600;
}

.collection-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.collection-item {
  position: relative;
  aspect-ratio: 1;
  border-radius: 24rpx;
  overflow: hidden;
  background: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(255, 105, 180, 0.1);
}

.collection-image {
  width: 100%;
  height: 100%;
}

.collection-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx;
  background: linear-gradient(to top, rgba(0,0,0,0.6), transparent);
}

.collection-category {
  display: inline-block;
  padding: 6rpx 16rpx;
  background: rgba(255,255,255,0.9);
  color: #FF69B4;
  font-size: 20rpx;
  font-weight: bold;
  border-radius: 20rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  display: block;
  font-size: 28rpx;
  color: #999999;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.empty-desc {
  display: block;
  font-size: 24rpx;
  color: #CCCCCC;
}

.fab-btn {
  position: fixed;
  right: 32rpx;
  bottom: 120rpx;
  width: 112rpx;
  height: 112rpx;
  border-radius: 56rpx;
  background: linear-gradient(135deg, #FF69B4, #FFB6C1);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 105, 180, 0.3);
  z-index: 50;
}

.fab-icon {
  font-size: 48rpx;
  color: #FFFFFF;
  font-weight: 300;
  line-height: 1;
}

.add-btn {
  width: 96rpx;
  height: 96rpx;
  border-radius: 9999rpx;
  background-color: #f472b6;
  box-shadow: 0 10rpx 15rpx -3rpx rgba(0, 0, 0, 0.1), 0 4rpx 6rpx -4rpx rgba(0, 0, 0, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-text {
  font-size: 60rpx;
  font-weight: bold;
  color: #FFFFFF;
  line-height: 1;
}
