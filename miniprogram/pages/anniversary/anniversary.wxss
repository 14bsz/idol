page { background-color: #FFF5F5; color: #333; }
.container { min-height: 100vh; padding: 0 30rpx 120rpx; box-sizing: border-box; }

/* 头部 */
.header { display: flex; justify-content: space-between; align-items: center; padding: 32rpx 30rpx; padding-top: 96rpx; margin: 0 -30rpx 24rpx; background: rgba(255, 249, 240, 0.85); backdrop-filter: blur(24rpx); position: sticky; top: 0; z-index: 100; }
.header-left, .header-right { width: 80rpx; height: 80rpx; display: flex; align-items: center; justify-content: center; border-radius: 50%; transition: all 0.3s; flex-shrink: 0; }
.header-left:active, .header-right:active { background: rgba(0, 0, 0, 0.05); }
.back-icon { font-size: 64rpx; color: #334155; font-weight: 300; margin-top: -8rpx; line-height: 1; }
.header-title { flex: 1; text-align: center; font-size: 32rpx; font-weight: bold; color: #1e293b; }

/* 卡片 */
.anniversary-card { background: #fff; padding: 30rpx; border-radius: 28rpx; display: flex; align-items: center; justify-content: space-between; margin-bottom: 24rpx; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03); transition: transform 0.2s; }
.card-hover { transform: scale(0.98); background: #fdfdfd; }
.date-badge { width: 90rpx; height: 90rpx; border-radius: 20rpx; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 40rpx; text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1); }
.info { margin-left: 24rpx; }
.item-title { display: block; font-size: 32rpx; font-weight: 600; }
.item-date { font-size: 24rpx; color: #ACB1C0; }
.card-right { display: flex; align-items: center; }
.days-info { display: flex; align-items: baseline; }
.more-icon { width: 36rpx; height: 36rpx; margin-left: 16rpx; opacity: 0.8; }
.days-num { font-size: 40rpx; font-weight: 800; color: #ec4899; }
.days-unit { font-size: 24rpx; color: #888; margin-left: 4rpx; }

/* 添加按钮 */
.add-section {
  margin-top: 48rpx;
  width: 100%;
  display: flex;
  justify-content: center;
}

.add-btn {
  width: 100%;
  max-width: 600rpx;
  padding: 32rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #f472b6, #ec4899);
  color: white;
  font-size: 28rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-sizing: border-box;
  box-shadow: 0 12rpx 32rpx -12rpx rgba(236, 72, 153, 0.5);
}

.add-btn text:first-child {
  font-size: 32rpx;
}

/* 弹窗 */
.modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.4); display: flex; align-items: center; justify-content: center; z-index: 1000; padding: 48rpx; box-sizing: border-box; }
.modal-content { position: relative; z-index: 1001; width: 100%; max-width: 560rpx; background: #fff; border-radius: 48rpx; overflow: hidden; box-shadow: 0 50rpx 100rpx -24rpx rgba(0,0,0,0.25); }

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from { transform: translateY(20rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}
.modal-header { display: flex; align-items: center; justify-content: space-between; padding: 32rpx; border-bottom: 1px solid #fce4ec; }
.modal-title { font-weight: bold; color: #1e293b; text-align: center; display: block; font-size: 32rpx; }
.modal-close { width: 32rpx; height: 32rpx; display: flex; align-items: center; justify-content: center; color: #94a3b8; font-size: 40rpx; }
.modal-body { padding: 32rpx; }
.form-item { margin-bottom: 32rpx; }
.form-label { font-size: 28rpx; font-weight: bold; color: #334155; display: block; margin-bottom: 16rpx; }
.form-input { width: 100%; height: 88rpx; padding: 0 24rpx; border: 2rpx solid #fce4ec; border-radius: 24rpx; font-size: 28rpx; line-height: 88rpx; box-sizing: border-box; background: #fff; display: flex; align-items: center; }
.form-input.picker { color: #1e293b; }
.modal-footer { display: flex; gap: 24rpx; padding: 32rpx; border-top: 1px solid #fce4ec; }
.btn-cancel, .btn-save { flex: 1; padding: 28rpx; border-radius: 24rpx; text-align: center; font-size: 28rpx; font-weight: bold; }
.btn-cancel { background: #f1f5f9; color: #64748b; }
.btn-save { background: linear-gradient(135deg, #f472b6, #ec4899); color: white; }
.empty-state { text-align: center; margin-top: 200rpx; color: #ccc; }
.main-list { height: calc(100vh - 200rpx); }

/* 提醒配置区域 */
.reminder-section { margin-top: 40rpx; padding-top: 32rpx; border-top: 2rpx dashed #f1f5f9; }
.reminder-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 24rpx; }
.reminder-title { font-size: 28rpx; font-weight: bold; color: #334155; }
.reminder-subtitle { font-size: 22rpx; color: #ec4899; }
.reminder-option { display: flex; justify-content: space-between; align-items: center; padding: 24rpx; background: #f8fafc; border-radius: 20rpx; margin-bottom: 16rpx; }
.reminder-info { flex: 1; }
.reminder-name { display: flex; align-items: center; font-size: 28rpx; font-weight: 600; color: #1e293b; margin-bottom: 8rpx; }
.reminder-desc { font-size: 22rpx; color: #64748b; display: block; }
.reminder-switch-wrap { display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.reminder-switch { margin-right: 0; }
