.crop-page {
  min-height: 100vh;
  box-sizing: border-box;
  background: #FFF5F5;
  color: #1e293b;
  display: flex;
  flex-direction: column;
}

.crop-header {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  box-sizing: border-box;
  z-index: 20;
}

.header-action {
  min-width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #94a3b8;
}

.back-icon {
  font-size: 56rpx;
  font-weight: 300;
  line-height: 1;
  margin-top: -8rpx;
}

.header-title-group {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.header-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1e293b;
  letter-spacing: 0.02em;
}

.header-subtitle {
  font-size: 22rpx;
  color: #94a3b8;
  letter-spacing: 0.08em;
  font-weight: 600;
  text-transform: uppercase;
}

.crop-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 24rpx 180rpx;
  box-sizing: border-box;
}

.crop-tip {
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 24rpx;
  background: rgba(255, 255, 255, 0.95);
  padding: 16rpx 28rpx;
  border-radius: 999rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 105, 180, 0.08);
  position: relative;
  z-index: 20;
  line-height: 1.5;
  letter-spacing: 0.02em;
}

.crop-stage {
  flex: 1;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 0;
  padding: 24rpx 0;
}

.crop-frame-shell {
  position: relative;
  box-shadow: 0 16rpx 48rpx rgba(244, 114, 182, 0.2);
}

.avatar-frame {
  border-radius: 32rpx;
}

.banner-frame {
  border-radius: 48rpx;
}

.crop-viewport {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
  border-radius: inherit;
  background: rgba(255, 255, 255, 0.8);
}

.crop-frame-shell::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  box-shadow: 0 0 0 200vmax rgba(255, 245, 245, 0.7);
  pointer-events: none;
  z-index: 5;
}

.crop-frame-highlight {
  position: absolute;
  inset: 0;
  border-radius: inherit;
  border: 4rpx solid #f472b6;
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.5);
  pointer-events: none;
  z-index: 10;
}

.crop-image {
  position: absolute;
  max-width: none;
  max-height: none;
  will-change: transform, left, top;
}

.crop-loading {
  font-size: 28rpx;
  color: #94a3b8;
}

.crop-footer {
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  position: relative;
  z-index: 20;
  padding: 0 32rpx;
}

.footer-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1e293b;
  letter-spacing: 0.02em;
}

.footer-desc {
  font-size: 22rpx;
  color: #94a3b8;
  text-align: center;
  line-height: 1.65;
  max-width: 520rpx;
  letter-spacing: 0.01em;
}

.crop-bottom-bar {
  position: fixed;
  bottom: calc(48rpx + env(safe-area-inset-bottom));
  left: 32rpx;
  right: 32rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20px);
  border-radius: 999rpx;
  padding: 16rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  z-index: 100;
  box-shadow: 0 16rpx 48rpx rgba(244, 114, 182, 0.15);
  border: 2rpx solid rgba(255, 255, 255, 0.5);
}

.bottom-action {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 800;
  transition: all 0.2s;
}

.bottom-action:active {
  transform: scale(0.96);
}

.bottom-action.secondary {
  background: #f8fafc;
  color: #64748b;
  border: 2rpx solid #e2e8f0;
}

.bottom-action.primary {
  background: linear-gradient(135deg, #f472b6, #ec4899);
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(236, 72, 153, 0.3);
}

.bottom-action.primary.disabled {
  opacity: 0.6;
  pointer-events: none;
}

.hidden-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  opacity: 0;
  pointer-events: none;
}
