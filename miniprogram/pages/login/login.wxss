.login-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #fffaf8 0%, #fdf2f8 50%, #fce7f3 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.login-content {
  width: 100%;
  max-width: 600rpx;
}

.logo-section {
  text-align: center;
  margin-bottom: 120rpx;
}

.logo-icon {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #f472b6 0%, #ec4899 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 32rpx;
  box-shadow: 0 20rpx 60rpx -10rpx rgba(236, 72, 153, 0.4);
}

.logo-icon text {
  font-size: 80rpx;
}

.app-name {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #1e293b;
  margin-bottom: 16rpx;
}

.app-slogan {
  display: block;
  font-size: 28rpx;
  color: #64748b;
}

.login-btn-section {
  margin-bottom: 120rpx;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 10rpx 30rpx -10rpx rgba(7, 193, 96, 0.4);
  border: none;
  outline: none;
}

.login-btn::after {
  border: none;
}

.login-btn.loading {
  opacity: 0.7;
}

.login-tip {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 32rpx;
}

.features-section {
  display: flex;
  justify-content: space-around;
  padding: 0 24rpx;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.feature-icon {
  font-size: 48rpx;
}

.feature-text {
  font-size: 24rpx;
  color: #64748b;
}
