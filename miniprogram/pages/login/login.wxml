<view class="login-container">
  <!-- 自定义返回按钮，动态适配胶囊高度和位置 -->
  <view 
    class="custom-back-btn" 
    style="top: {{navTop}}px; left: {{navLeft}}px; width: {{navHeight}}px; height: {{navHeight}}px;" 
    bindtap="onBack"
    hover-class="custom-back-btn-hover"
  >
    <text class="back-arrow"></text>
  </view>

  <view class="login-content">
    <view class="logo-section">
      <view class="logo-icon">
        <text>✨</text>
      </view>
      <text class="app-name">爱豆时光日记</text>
      <text class="app-slogan">记录每一份心动时刻</text>
    </view>

    <view class="login-btn-section">
      <button 
        class="login-btn {{loading ? 'loading' : ''}} {{!agreed ? 'pending' : ''}}" 
        bindtap="onWechatLogin"
        disabled="{{loading}}"
      >
        <text wx:if="{{!loading}}">微信一键登录</text>
        <text wx:else>登录中...</text>
      </button>

      <view class="agreement-panel">
        <view class="agreement-check" bindtap="onToggleAgreement">
          <view class="agreement-checkbox {{agreed ? 'checked' : ''}}">
            <text wx:if="{{agreed}}" class="agreement-checkbox-icon">✓</text>
          </view>
          <view class="agreement-text-group">
            <text class="agreement-prefix">我已阅读并同意</text>
            <text class="agreement-link" catchtap="onOpenUserAgreement">《用户协议》</text>
            <text class="agreement-separator">和</text>
            <text class="agreement-link" catchtap="onOpenPrivacyPolicy">《隐私政策》</text>
          </view>
        </view>
      </view>
    </view>

    <view class="features-section">
      <view class="feature-item">
        <text class="feature-icon">💝</text>
        <text class="feature-text">记录追星时光</text>
      </view>
      <view class="feature-item">
        <text class="feature-icon">🎁</text>
        <text class="feature-text">收藏美好瞬间</text>
      </view>
      <view class="feature-item">
        <text class="feature-icon">📅</text>
        <text class="feature-text">重要日程提醒</text>
      </view>
    </view>
  </view>
</view>
