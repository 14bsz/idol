<view class="container">
  <!-- 顶部标题区 -->
  <view class="page-header">
    <view bindtap="{{showAddForm ? 'hideAddForm' : 'goBack'}}" class="back-btn">
      <text>‹</text>
    </view>
    <view class="header-center">
    <view class="header-title">{{showAddForm ? (editingIdol ? '编辑档案' : '添加爱豆') : '我的爱豆'}}</view>
      <text class="header-subtitle">{{showAddForm ? 'Fandom Memory' : 'My Idols Collection'}}</text>
    </view>
    <view class="header-right">
      <view wx:if="{{!showAddForm && idols.length > 0}}" bindtap="toggleManageMode" class="manage-btn {{isManageMode ? 'manage-btn-active' : ''}}">
        <text>{{isManageMode ? '取消' : '管理'}}</text>
      </view>
    </view>
  </view>

  <!-- 爱豆卡片列表 -->
  <view wx:if="{{!showAddForm}}" class="idol-list">
    <block wx:for="{{idols}}" wx:key="id">
      <view class="idol-card {{isManageMode ? 'idol-card-manage' : ''}}" hover-class="{{isManageMode ? '' : 'card-hover'}}" bindtap="{{isManageMode ? '' : 'switchIdol'}}" data-id="{{item.id}}">
        <view class="card-left">
          <view class="avatar-container">
            <image src="{{item.avatar}}" class="avatar" mode="aspectFill" />
            <view wx:if="{{item.id === currentIdolId && !isManageMode}}" class="active-badge">
              <text>✓</text>
            </view>
          </view>
          <view class="idol-info">
            <view class="idol-name">{{item.name}}</view>
            <view class="idol-nickname">@{{item.nickname || 'STAR'}}</view>
          </view>
        </view>
        <view class="card-right">
          <!-- 普通模式：编辑按钮 -->
          <view wx:if="{{!isManageMode}}" catchtap="editIdol" data-id="{{item.id}}" class="edit-btn">
            <text>✏️</text>
          </view>
          <!-- 管理模式：删除按钮 -->
          <view wx:else catchtap="confirmDeleteIdol" data-id="{{item.id}}" data-name="{{item.name}}" class="delete-btn-icon">
            <text>🗑️</text>
          </view>
        </view>
      </view>
    </block>

    <!-- 空状态 -->
    <view wx:if="{{idols.length === 0}}" class="empty-state">
      <view class="empty-icon">
        <text>✨</text>
      </view>
      <text class="empty-title">还没有添加爱豆</text>
      <text class="empty-desc">开始记录你的追星时光吧</text>
    </view>

    <!-- 添加按钮 -->
    <view class="add-section">
      <view bindtap="showAddForm" class="add-btn">
        <text>+</text>
        <text>添加新爱豆</text>
      </view>
    </view>
  </view>

  <!-- 编辑/添加表单 -->
  <view wx:else class="form-container">
    <view class="avatar-section">
      <view class="avatar-wrapper" bindtap="onChooseAvatar">
        <view wx:if="{{!newAvatar}}" class="avatar-placeholder">
          <image src="/images/avatar-placeholder.svg" class="avatar-placeholder-icon" mode="aspectFit" />
        </view>
        <image wx:else src="{{newAvatar}}" class="form-avatar" mode="aspectFill" />
        <view catchtap="onChooseAvatar" class="camera-btn">
          <image src="/images/camera.svg" class="camera-icon" mode="aspectFit" />
        </view>
      </view>
    </view>

    <view class="field-group banner-field-group">
      <text class="field-label">爱豆壁纸</text>
      <view class="banner-upload-card" bindtap="onChooseBanner">
        <image
          wx:if="{{newBannerImage}}"
          src="{{newBannerImage}}"
          class="banner-upload-image"
          mode="aspectFill"
        />
        <view wx:else class="banner-upload-placeholder">
          <text class="banner-upload-placeholder-title">点击上传爱豆壁纸</text>
          <text class="banner-upload-placeholder-desc">首页横幅会优先展示你上传的图片</text>
        </view>
        <view class="banner-upload-mask">
          <text class="banner-upload-text">{{newBannerImage ? '更换壁纸' : '上传壁纸'}}</text>
        </view>
      </view>
    </view>

    <view class="form-fields">
      <view class="field-group">
        <text class="field-label">爱豆本名 / 艺名</text>
        <input 
          class="field-input" 
          placeholder="如：田柾国 / Jungkook" 
          placeholder-style="font-size:26rpx;color:#cbd5e1;font-family:sans-serif;line-height:1.5;"
          value="{{newName}}" 
          bindinput="onNameInput"
        />
      </view>

      <view class="field-group">
        <text class="field-label">专属昵称</text>
        <input 
          class="field-input" 
          placeholder="如：果子 / JK" 
          placeholder-style="font-size:26rpx;color:#cbd5e1;font-family:sans-serif;line-height:1.5;"
          value="{{newNickname}}" 
          bindinput="onNicknameInput"
        />
      </view>

      <view class="field-group">
        <text class="field-label">你的入坑日期</text>
        <picker mode="date" value="{{newEntryDate}}" bindchange="onEntryDateChange">
          <view class="field-input picker">
            {{newEntryDate || '请选择日期'}}
          </view>
        </picker>
      </view>

      <view class="field-group">
        <text class="field-label">生日</text>
        <picker mode="date" value="{{newBirthday}}" bindchange="onBirthdayChange">
          <view class="field-input picker">
            {{newBirthday || '请选择'}}
          </view>
        </picker>
      </view>

      <view class="field-group">
        <text class="field-label">出道日</text>
        <picker mode="date" value="{{newDebutDate}}" bindchange="onDebutDateChange">
          <view class="field-input picker">
            {{newDebutDate || '请选择'}}
          </view>
        </picker>
      </view>

      <view class="field-group">
        <text class="field-label">应援色</text>
        <view class="color-preview" bindtap="showColorPicker">
          <view class="color-preview-circle" style="background-color: {{newSupportColor}};"></view>
          <text class="color-preview-text">{{selectedColorName}}</text>
          <text class="color-preview-arrow">›</text>
        </view>
      </view>
    </view>

    <view class="form-actions">
      <view bindtap="hideAddForm" class="cancel-btn">
        取消
      </view>
      <view bindtap="{{editingIdol ? 'updateIdol' : 'addIdol'}}" class="submit-btn">
        {{editingIdol ? '保存修改' : '确认入坑'}}
      </view>
    </view>
  </view>

  <!-- 删除确认弹窗 -->
  <view wx:if="{{showDeleteModal}}" class="delete-modal-overlay" bindtap="hideDeleteModal">
    <view class="delete-modal" catchtap="stopPropagation">
      <view class="delete-modal-icon">
        <text>⚠️</text>
      </view>
      <view class="delete-modal-title">确认删除爱豆？</view>
      <view class="delete-modal-desc">
        删除后，与"{{deletingIdolName}}"相关的所有日记、纪念日等数据都将被永久删除，此操作无法撤销。
      </view>
      <view class="delete-modal-actions">
        <view bindtap="hideDeleteModal" class="delete-modal-cancel">
          取消
        </view>
        <view bindtap="executeDeleteIdol" class="delete-modal-confirm">
          确认删除
        </view>
      </view>
    </view>
  </view>

  <!-- 颜色选择器弹窗 -->
  <view wx:if="{{showColorModal}}" class="color-modal-overlay" bindtap="hideColorPicker">
    <view class="color-modal" catchtap="stopPropagation">
      <view class="color-modal-header">
        <text class="color-modal-title">选择应援色</text>
        <view class="color-modal-close" bindtap="hideColorPicker">✕</view>
      </view>
      
      <scroll-view class="color-modal-content" scroll-y="true" enable-flex="true">
        <view class="color-category" wx:for="{{colorCategories}}" wx:key="category">
          <text class="category-title">{{item.category}}</text>
          <view class="color-grid">
            <block wx:for="{{item.colors}}" wx:key="value" wx:for-item="color">
              <view 
                class="color-item {{newSupportColor === color.value ? 'active' : ''}}"
                bindtap="onColorSelect"
                data-color="{{color.value}}"
                data-name="{{color.name}}"
                style="--theme-color: {{color.value}};"
              >
                <view class="color-circle" style="background-color: {{color.value}};"></view>
                <text class="color-name">{{color.name}}</text>
              </view>
            </block>
          </view>
        </view>
      </scroll-view>
      
      <view class="color-modal-footer">
        <view class="color-confirm-btn" bindtap="hideColorPicker">
          确定
        </view>
      </view>
    </view>
  </view>
</view>
