page {
  background-color: #FFF5F5;
}

.container {
  padding-top: 120rpx;
  padding-left: 32rpx;
  padding-right: 32rpx;
  padding-bottom: 96px;
  width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 页面头部 */
.page-header {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 48rpx;
  position: relative;
  width: 100%;
}

.back-btn {
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #cbd5e1;
  font-weight: bold;
}

.header-center {
  text-align: center;
}

.header-title {
  font-size: 48rpx;
  font-weight: 800;
  color: #1e293b;
}

.header-subtitle {
  font-size: 20rpx;
  color: #94a3b8;
  letter-spacing: 0.2em;
  font-weight: 700;
  text-transform: uppercase;
  margin-top: 4rpx;
  display: block;
}

/* 爱豆列表 */
.idol-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  width: 100%;
  max-width: 600rpx;
  align-items: center;
}

/* 爱豆卡片 */
.idol-card {
  background: #ffffff;
  padding: 32rpx;
  border-radius: 36rpx;
  border: 2rpx solid #f8fafc;
  box-shadow: 0 10rpx 25rpx -5rpx rgba(0,0,0,0.05);
  transition: transform 0.2s;
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
}

.card-hover {
  transform: scale(0.98);
  background: #fdfdfd;
}

.card-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
  flex: 1;
}

.avatar-container {
  position: relative;
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 32rpx;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.active-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 32rpx;
  height: 32rpx;
  background: #ec4899;
  border-radius: 50%;
  border: 4rpx solid #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.active-badge text {
  color: white;
  font-size: 16rpx;
}

.idol-info {
  flex: 1;
}

.idol-name {
  font-size: 32rpx;
  font-weight: 800;
  color: #1e293b;
  display: block;
}

.idol-nickname {
  font-size: 24rpx;
  color: #94a3b8;
  font-weight: 600;
  margin-top: 4rpx;
  display: block;
}

.edit-btn {
  padding: 16rpx;
  background: #f1f5f9;
  border-radius: 20rpx;
}

.edit-btn text {
  font-size: 32rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 24rpx;
  text-align: center;
  width: 100%;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #fce4ec;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.empty-icon text {
  font-size: 48rpx;
}

.empty-title {
  font-size: 20px;
  font-weight: bold;
  color: #1e293b;
  margin-bottom: 12rpx;
  display: block;
}

.empty-desc {
  font-size: 14px;
  color: #94a3b8;
  margin-bottom: 32rpx;
  display: block;
}

/* 添加按钮 */
.add-section {
  margin-top: 48rpx;
  width: 100%;
  display: flex;
  justify-content: center;
}

.add-btn {
  width: 100%;
  max-width: 600rpx;
  padding: 32rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #f472b6, #ec4899);
  color: white;
  font-size: 28rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-sizing: border-box;
  box-shadow: 0 12rpx 32rpx -12rpx rgba(236, 72, 153, 0.5);
}

.add-btn text:first-child {
  font-size: 32rpx;
}

/* 表单容器 */
.form-container {
  margin-top: 24rpx;
  width: 100%;
  max-width: 600rpx;
}

/* 头像区域 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 64rpx;
}

.avatar-wrapper {
  position: relative;
}

.form-avatar {
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  border: 8rpx solid #fff;
  box-shadow: 0 20rpx 25rpx -5rpx rgba(0,0,0,0.1);
}

.camera-btn {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #f472b6, #ec4899);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 16rpx -3rpx rgba(236, 72, 153, 0.4);
  border: 4rpx solid #fff;
}

.avatar-placeholder {
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #fce4ec, #f8bbd0);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 8rpx solid #fff;
  box-shadow: 0 20rpx 25rpx -5rpx rgba(0,0,0,0.1);
}

.avatar-placeholder-icon {
  width: 100rpx;
  height: 100rpx;
}

.camera-icon {
  width: 44rpx;
  height: 44rpx;
}

.banner-field-group {
  margin-bottom: 28rpx;
}

.banner-upload-card {
  position: relative;
  width: 100%;
  height: 576rpx;
  border-radius: 32rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #fff1f6, #f8fafc);
  border: 2rpx solid #ffe4ec;
  box-shadow: 0 10rpx 30rpx rgba(255, 105, 180, 0.08);
}

.banner-upload-image {
  width: 100%;
  height: 100%;
}

.banner-upload-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 32rpx;
  box-sizing: border-box;
  text-align: center;
}

.banner-upload-placeholder-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1e293b;
}

.banner-upload-placeholder-desc {
  font-size: 22rpx;
  color: #94a3b8;
  line-height: 1.6;
}

.banner-upload-mask {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  display: flex;
  justify-content: center;
}

.banner-upload-text {
  min-width: 176rpx;
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.48);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
  backdrop-filter: blur(12rpx);
}

/* 表单区域 */
.form-fields {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  width: 100%;
}

.field-group {
  display: flex;
  flex-direction: column;
}

.field-label {
  font-size: 22rpx;
  color: #94a3b8;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  margin-bottom: 10rpx;
  display: block;
}

.field-input {
  width: 100%;
  padding: 28rpx 28rpx;
  border-radius: 28rpx;
  background: #ffffff;
  font-weight: 600;
  font-size: 28rpx;
  line-height: 1.5;
  color: #1e293b;
  font-family: sans-serif;
  box-sizing: border-box;
  border: 2rpx solid #ffe4ec;
  box-shadow: 0 4rpx 16rpx rgba(255, 105, 180, 0.08);
  transition: border-color 0.2s;
  min-height: 88rpx;
}

.field-input.picker {
  color: #1e293b;
  background: #ffffff;
  border: 2rpx solid #ffe4ec;
  box-shadow: 0 4rpx 16rpx rgba(255, 105, 180, 0.08);
}

/* 按钮区域 */
.form-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 48rpx;
  justify-content: center;
}

.cancel-btn, .submit-btn {
  flex: 1;
  padding: 28rpx;
  border-radius: 24rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
  max-width: 280rpx;
}

.cancel-btn {
  background: #f1f5f9;
  color: #64748b;
}

.submit-btn {
  background: linear-gradient(135deg, #f472b6, #ec4899);
  color: white;
  box-shadow: 0 12rpx 32rpx -12rpx rgba(236, 72, 153, 0.4);
}

/* 颜色选择器 */
.color-preview {
  display: inline-flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 32rpx 16rpx 16rpx;
  background: #f8fafc;
  border-radius: 100rpx;
  align-self: flex-start;
  border: 2rpx solid #f1f5f9;
  transition: all 0.2s;
}

.color-preview:active {
  background: #f1f5f9;
  transform: scale(0.98);
}

.color-preview-circle {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(0,0,0,0.08);
  flex-shrink: 0;
}

.color-preview-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #475569;
}

.color-preview-arrow {
  font-size: 28rpx;
  color: #94a3b8;
  font-weight: bold;
  margin-left: 4rpx;
}

/* 颜色选择弹窗 */
.color-modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.color-modal {
  width: 100%;
  max-width: 640rpx;
  max-height: 80vh;
  background: #ffffff;
  border-radius: 48rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  box-shadow: 0 40rpx 80rpx rgba(0,0,0,0.3);
}

.color-modal-header {
  padding: 40rpx 48rpx;
  border-bottom: 2rpx solid #f1f5f9;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-shrink: 0;
}

.color-modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1e293b;
}

.color-modal-close {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #94a3b8;
  border-radius: 50%;
  background: #f1f5f9;
}

.color-modal-content {
  flex: 1;
  padding: 32rpx 32rpx 32rpx 32rpx;
  overflow-y: scroll;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  box-sizing: border-box;
}

.color-category {
  margin-bottom: 48rpx;
  width: 100%;
  max-width: 560rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.category-title {
  font-size: 24rpx;
  font-weight: bold;
  color: #64748b;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 24rpx;
  display: block;
  text-align: center;
  width: 100%;
}

.color-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  justify-items: center;
  width: 100%;
  padding: 0 8rpx;
  box-sizing: border-box;
}

.color-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 20rpx 8rpx;
  border-radius: 32rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  width: 100%;
  max-width: 160rpx;
  background: transparent;
}

.color-item:active {
  transform: scale(0.92);
}

.color-item.active {
  background: rgba(255, 255, 255, 0.6);
  box-shadow: 0 8rpx 24rpx -4rpx rgba(0,0,0,0.05);
}

.color-circle {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  border: 4rpx solid #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  position: relative;
}

.color-item.active .color-circle {
  transform: scale(1.15);
  box-shadow: 0 0 0 4rpx rgba(255, 255, 255, 0.8), 0 0 0 8rpx var(--theme-color, #f472b6), 0 12rpx 24rpx -6rpx rgba(0,0,0,0.25);
  border-color: transparent;
}

@keyframes scaleIn {
  from {
    transform: scale(0);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}

.color-name {
  font-size: 22rpx;
  color: #94a3b8;
  font-weight: 600;
  text-align: center;
  transition: all 0.3s;
}

.color-item.active .color-name {
  color: #334155;
  font-weight: 800;
}

.color-modal-footer {
  padding: 24rpx 48rpx;
  border-top: 2rpx solid #f1f5f9;
  flex-shrink: 0;
  display: flex;
  justify-content: center;
  align-items: center;
}

.color-confirm-btn {
  width: 100%;
  padding: 28rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #f472b6, #ec4899);
  color: white;
  font-size: 28rpx;
  font-weight: bold;
  text-align: center;
  box-shadow: 0 12rpx 32rpx -12rpx rgba(236, 72, 153, 0.4);
}

/* 管理按钮 */
.header-right {
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  margin-top: 24rpx;
}

.manage-btn {
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #fef3f8, #fce4ec);
  border: 2rpx solid #fbd5e4;
  font-size: 24rpx;
  font-weight: 700;
  color: #ec4899;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 2rpx 8rpx rgba(236, 72, 153, 0.1);
}

.manage-btn:active {
  transform: scale(0.95);
}

.manage-btn-active {
  background: linear-gradient(135deg, #ec4899, #db2777);
  border-color: #db2777;
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(236, 72, 153, 0.3);
}

/* 管理模式下的卡片 */
.idol-card-manage {
  border: 2rpx solid #fee2e2;
  background: #fffafa;
}

.idol-card-manage .idol-name {
  color: #475569;
}

/* 删除图标按钮 */
.delete-btn-icon {
  padding: 16rpx;
  background: linear-gradient(135deg, #fef2f2, #fee2e2);
  border-radius: 20rpx;
  border: 2rpx solid #fecaca;
  transition: all 0.2s;
}

.delete-btn-icon:active {
  transform: scale(0.9);
  background: linear-gradient(135deg, #fee2e2, #fecaca);
}

.delete-btn-icon text {
  font-size: 32rpx;
}

/* 删除确认弹窗 */
.delete-modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.6);
  z-index: 2000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.delete-modal {
  width: 100%;
  max-width: 560rpx;
  background: #ffffff;
  border-radius: 40rpx;
  padding: 56rpx 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 40rpx 80rpx rgba(0,0,0,0.3);
}

.delete-modal-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #fef2f2, #fee2e2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.delete-modal-icon text {
  font-size: 56rpx;
}

.delete-modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1e293b;
  margin-bottom: 20rpx;
  text-align: center;
}

.delete-modal-desc {
  font-size: 26rpx;
  color: #64748b;
  line-height: 1.6;
  text-align: center;
  margin-bottom: 48rpx;
  padding: 0 8rpx;
}

.delete-modal-actions {
  display: flex;
  gap: 20rpx;
  width: 100%;
}

.delete-modal-cancel,
.delete-modal-confirm {
  flex: 1;
  padding: 28rpx;
  border-radius: 24rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
}

.delete-modal-cancel {
  background: #f1f5f9;
  color: #64748b;
}

.delete-modal-confirm {
  background: linear-gradient(135deg, #f87171, #dc2626);
  color: white;
  box-shadow: 0 12rpx 32rpx -12rpx rgba(220, 38, 38, 0.4);
}
