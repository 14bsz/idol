page {
  background-color: #FFF5F5;
}

.container {
  padding-top: 120rpx;
  padding-left: 32rpx;
  padding-right: 32rpx;
  padding-bottom: 96px;
  width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 页面头部 */
.page-header {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 48rpx;
  position: relative;
  width: 100%;
}

.back-btn {
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #cbd5e1;
  font-weight: bold;
}

.header-center {
  text-align: center;
}

.header-title {
  font-size: 48rpx;
  font-weight: 800;
  color: #1e293b;
}

.header-subtitle {
  font-size: 20rpx;
  color: #94a3b8;
  letter-spacing: 0.2em;
  font-weight: 700;
  text-transform: uppercase;
  margin-top: 4rpx;
  display: block;
}

/* 爱豆列表 */
.idol-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  width: 100%;
  max-width: 600rpx;
  align-items: center;
}

/* 爱豆卡片 */
.idol-card {
  background: #ffffff;
  padding: 32rpx;
  border-radius: 36rpx;
  border: 2rpx solid #f8fafc;
  box-shadow: 0 10rpx 25rpx -5rpx rgba(0,0,0,0.05);
  transition: transform 0.2s;
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
}

.card-hover {
  transform: scale(0.98);
  background: #fdfdfd;
}

.card-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
  flex: 1;
}

.avatar-container {
  position: relative;
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 32rpx;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.active-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 32rpx;
  height: 32rpx;
  background: #ec4899;
  border-radius: 50%;
  border: 4rpx solid #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.active-badge text {
  color: white;
  font-size: 16rpx;
}

.idol-info {
  flex: 1;
}

.idol-name {
  font-size: 32rpx;
  font-weight: 800;
  color: #1e293b;
  display: block;
}

.idol-nickname {
  font-size: 24rpx;
  color: #94a3b8;
  font-weight: 600;
  margin-top: 4rpx;
  display: block;
}

.edit-btn {
  padding: 16rpx;
  background: #f1f5f9;
  border-radius: 20rpx;
}

.edit-btn text {
  font-size: 32rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 24rpx;
  text-align: center;
  width: 100%;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #fce4ec;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.empty-icon text {
  font-size: 48rpx;
}

.empty-title {
  font-size: 20px;
  font-weight: bold;
  color: #1e293b;
  margin-bottom: 12rpx;
  display: block;
}

.empty-desc {
  font-size: 14px;
  color: #94a3b8;
  margin-bottom: 32rpx;
  display: block;
}

/* 添加按钮 */
.add-section {
  margin-top: 48rpx;
  width: 100%;
  display: flex;
  justify-content: center;
}

.add-btn {
  width: 100%;
  max-width: 600rpx;
  padding: 32rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #f472b6, #ec4899);
  color: white;
  font-size: 28rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-sizing: border-box;
  box-shadow: 0 12rpx 32rpx -12rpx rgba(236, 72, 153, 0.5);
}

.add-btn text:first-child {
  font-size: 32rpx;
}

/* 表单容器 */
.form-container {
  margin-top: 24rpx;
  width: 100%;
  max-width: 600rpx;
}

/* 头像区域 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 64rpx;
}

.avatar-wrapper {
  position: relative;
}

.form-avatar {
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  border: 8rpx solid #fff;
  box-shadow: 0 20rpx 25rpx -5rpx rgba(0,0,0,0.1);
}

.camera-btn {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 80rpx;
  height: 80rpx;
  background: #1e293b;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 15rpx -3rpx rgba(0,0,0,0.1);
}

.camera-btn text {
  font-size: 36rpx;
}

/* 表单区域 */
.form-fields {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  width: 100%;
}

.field-group {
  display: flex;
  flex-direction: column;
}

.field-label {
  font-size: 22rpx;
  color: #94a3b8;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  margin-bottom: 10rpx;
  display: block;
}

.field-input {
  width: 100%;
  padding: 24rpx 28rpx;
  border-radius: 28rpx;
  background: #f8fafc;
  font-weight: 600;
  font-size: 28rpx;
  color: #1e293b;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: border-color 0.2s;
}

.field-input.picker {
  color: #1e293b;
}

/* 按钮区域 */
.form-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 48rpx;
  justify-content: center;
}

.cancel-btn, .submit-btn {
  flex: 1;
  padding: 28rpx;
  border-radius: 24rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
  max-width: 280rpx;
}

.cancel-btn {
  background: #f1f5f9;
  color: #64748b;
}

.submit-btn {
  background: linear-gradient(135deg, #f472b6, #ec4899);
  color: white;
  box-shadow: 0 12rpx 32rpx -12rpx rgba(236, 72, 153, 0.4);
}
